@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "招聘管理页面"
participant "后端服务"
database "数据库"

== 查看招聘需求列表流程 ==

用户 -> "招聘管理页面": 进入招聘需求管理
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 请求招聘需求列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询招聘需求数据
activate "数据库"
"数据库" --> "后端服务": 返回需求列表
deactivate "数据库"
"后端服务" --> "招聘管理页面": 返回列表数据
deactivate "后端服务"
"招聘管理页面" --> 用户: 展示招聘需求列表
deactivate "招聘管理页面"

== 新增招聘需求流程 ==

用户 -> "招聘管理页面": 点击【新增需求】，填写信息
用户 -> "招聘管理页面": 点击【提交审批】
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 提交新增请求\n(携带需求数据)
activate "后端服务"
"后端服务" -> "数据库": 插入需求记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 创建审批流程
activate "数据库"
"数据库" --> "后端服务": 返回审批流程ID
deactivate "数据库"
"后端服务" --> "招聘管理页面": 返回成功响应
deactivate "后端服务"
"招聘管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "招聘管理页面"

== 职位发布流程 ==

用户 -> "招聘管理页面": 点击【发布职位】，填写职位信息
用户 -> "招聘管理页面": 选择发布渠道，点击【发布】
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 提交职位发布请求\n(携带职位数据和渠道)
activate "后端服务"
"后端服务" -> "数据库": 插入职位记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "后端服务": 调用第三方招聘平台API
"后端服务" --> "招聘管理页面": 返回发布结果
deactivate "后端服务"
"招聘管理页面" --> 用户: 显示发布成功\n刷新列表
deactivate "招聘管理页面"

== 简历筛选流程 ==

用户 -> "招聘管理页面": 进入简历管理，设置筛选条件
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 请求简历列表\n(携带筛选条件)
activate "后端服务"
"后端服务" -> "数据库": 查询简历数据
activate "数据库"
"数据库" --> "后端服务": 返回简历列表
deactivate "数据库"
"后端服务" --> "招聘管理页面": 返回筛选结果
deactivate "后端服务"
"招聘管理页面" --> 用户: 展示简历列表
deactivate "招聘管理页面"

== 安排面试流程 ==

用户 -> "招聘管理页面": 点击【安排面试】，填写面试信息
用户 -> "招聘管理页面": 选择面试官，点击【保存】
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 提交面试安排请求\n(携带面试数据)
activate "后端服务"
"后端服务" -> "数据库": 插入面试记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "后端服务": 发送面试通知\n(邮件/短信)
"后端服务" --> "招聘管理页面": 返回成功响应
deactivate "后端服务"
"招聘管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "招聘管理页面"

== 填写面试评价流程 ==

用户 -> "招聘管理页面": 点击【填写评价】按钮
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 请求面试详情
activate "后端服务"
"后端服务" -> "数据库": 查询面试记录
activate "数据库"
"数据库" --> "后端服务": 返回面试详情
deactivate "数据库"
"后端服务" --> "招聘管理页面": 返回面试数据
deactivate "后端服务"
"招聘管理页面" --> 用户: 打开评价弹窗\n回显数据
deactivate "招聘管理页面"

用户 -> "招聘管理页面": 填写评价内容，点击【保存】
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 提交评价数据
activate "后端服务"
"后端服务" -> "数据库": 更新面试记录
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "招聘管理页面": 返回成功响应
deactivate "后端服务"
"招聘管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "招聘管理页面"

== 发放Offer流程 ==

用户 -> "招聘管理页面": 点击【发放Offer】，填写Offer信息
用户 -> "招聘管理页面": 点击【提交审批】
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 提交Offer申请\n(携带Offer数据)
activate "后端服务"
"后端服务" -> "数据库": 插入Offer记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 创建审批流程
activate "数据库"
"数据库" --> "后端服务": 返回审批流程ID
deactivate "数据库"
"后端服务" --> "招聘管理页面": 返回成功响应
deactivate "后端服务"
"招聘管理页面" --> 用户: 显示成功提示\n等待审批
deactivate "招聘管理页面"

== 办理入职流程 ==

用户 -> "招聘管理页面": 点击【办理入职】，填写入职信息
用户 -> "招聘管理页面": 上传入职资料，点击【保存】
activate "招聘管理页面"
"招聘管理页面" -> "后端服务": 提交入职办理请求\n(携带入职数据)
activate "后端服务"
"后端服务" -> "数据库": 创建员工档案
activate "数据库"
"数据库" --> "后端服务": 返回员工ID
deactivate "数据库"
"后端服务" -> "数据库": 开通系统账号
activate "数据库"
"数据库" --> "后端服务": 返回账号信息
deactivate "数据库"
"后端服务" -> "数据库": 更新招聘状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "招聘管理页面": 返回成功响应
deactivate "后端服务"
"招聘管理页面" --> 用户: 显示入职成功\n刷新列表
deactivate "招聘管理页面"

@enduml
