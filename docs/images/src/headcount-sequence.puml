@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "编制管理页面"
participant "后端服务"
database "数据库"

== 查看编制计划列表 ==

用户 -> "编制管理页面": 进入编制管理页面\n（选择查看年度）
activate "编制管理页面"
"编制管理页面" -> "后端服务": 请求编制计划列表\n(携带年度、部门等查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询编制计划及在编人数
activate "数据库"
"数据库" --> "后端服务": 返回编制计划列表数据
deactivate "数据库"
"后端服务" --> "编制管理页面": 返回列表数据\n（含超编/缺编状态）
deactivate "后端服务"
"编制管理页面" --> 用户: 展示编制列表\n标记超编/缺编预警
deactivate "编制管理页面"

== 新增编制计划 ==

用户 -> "编制管理页面": 点击【新增】，选择年度和部门\n填写计划编制人数
用户 -> "编制管理页面": 点击【保存】
activate "编制管理页面"
"编制管理页面" -> "后端服务": 提交新增编制计划\n(年度、部门ID、计划人数)
activate "后端服务"
"后端服务" -> "数据库": 检查是否已存在同年度同部门编制
activate "数据库"
"数据库" --> "后端服务": 返回检查结果
deactivate "数据库"
"后端服务" -> "数据库": 插入编制计划记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "编制管理页面": 返回成功响应
deactivate "后端服务"
"编制管理页面" --> 用户: 显示保存成功提示\n刷新编制列表
deactivate "编制管理页面"

== 修改编制计划 ==

用户 -> "编制管理页面": 点击【编辑】按钮
activate "编制管理页面"
"编制管理页面" -> "后端服务": 请求编制计划详情
activate "后端服务"
"后端服务" -> "数据库": 查询编制计划详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "编制管理页面": 返回详情数据
deactivate "后端服务"
"编制管理页面" --> 用户: 打开编辑弹窗\n回显当前数据
deactivate "编制管理页面"

用户 -> "编制管理页面": 修改编制人数，点击【保存】
activate "编制管理页面"
"编制管理页面" -> "后端服务": 提交更新请求\n(编制计划ID、新编制人数)
activate "后端服务"
"后端服务" -> "数据库": 更新编制计划记录
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "编制管理页面": 返回成功响应
deactivate "后端服务"
"编制管理页面" --> 用户: 显示保存成功提示\n重新计算缺编/超编并刷新
deactivate "编制管理页面"

== 实时统计与预警 ==

用户 -> "编制管理页面": 触发统计刷新
activate "编制管理页面"
"编制管理页面" -> "后端服务": 请求各部门实时统计数据
activate "后端服务"
"后端服务" -> "数据库": 统计各部门在编人数
activate "数据库"
"数据库" --> "后端服务": 返回统计结果
deactivate "数据库"
"后端服务" --> "编制管理页面": 返回统计数据\n（含超编/缺编状态标记）
deactivate "后端服务"
"编制管理页面" --> 用户: 展示统计卡片\n红色标记超编、橙色标记缺编
deactivate "编制管理页面"

@enduml
