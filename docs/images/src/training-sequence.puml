@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "培训管理页面"
participant "后端服务"
database "数据库"

== 查看培训计划列表流程 ==

用户 -> "培训管理页面": 进入培训计划管理
activate "培训管理页面"
"培训管理页面" -> "后端服务": 请求培训计划列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询培训计划数据
activate "数据库"
"数据库" --> "后端服务": 返回计划列表
deactivate "数据库"
"后端服务" --> "培训管理页面": 返回列表数据
deactivate "后端服务"
"培训管理页面" --> 用户: 展示培训计划列表
deactivate "培训管理页面"

== 新增培训计划流程 ==

用户 -> "培训管理页面": 点击【新增计划】，填写信息
用户 -> "培训管理页面": 点击【保存】
activate "培训管理页面"
"培训管理页面" -> "后端服务": 提交新增请求\n(携带计划数据)
activate "后端服务"
"后端服务" -> "数据库": 插入计划记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "培训管理页面": 返回成功响应
deactivate "后端服务"
"培训管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "培训管理页面"

== 课程管理流程 ==

用户 -> "培训管理页面": 进入课程管理，点击【新增课程】
activate "培训管理页面"
用户 -> "培训管理页面": 填写课程信息，上传资料
"培训管理页面" -> "后端服务": 提交课程数据\n(携带课程信息和文件)
activate "后端服务"
"后端服务" -> "数据库": 插入课程记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "后端服务": 保存课程资料文件
"后端服务" --> "培训管理页面": 返回成功响应
deactivate "后端服务"
"培训管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "培训管理页面"

== 培训记录签到流程 ==

用户 -> "培训管理页面": 进入培训记录，点击【签到】
activate "培训管理页面"
"培训管理页面" -> "后端服务": 请求签到二维码
activate "后端服务"
"后端服务" --> "培训管理页面": 返回二维码数据
deactivate "后端服务"
"培训管理页面" --> 用户: 展示签到二维码
deactivate "培训管理页面"

用户 -> "培训管理页面": 扫描二维码或手动签到
activate "培训管理页面"
"培训管理页面" -> "后端服务": 提交签到请求\n(携带员工ID和培训ID)
activate "后端服务"
"后端服务" -> "数据库": 插入签到记录
activate "数据库"
"数据库" --> "后端服务": 返回签到结果
deactivate "数据库"
"后端服务" --> "培训管理页面": 返回成功响应
deactivate "后端服务"
"培训管理页面" --> 用户: 显示签到成功\n刷新列表
deactivate "培训管理页面"

== 培训评估流程 ==

用户 -> "培训管理页面": 点击【发起评估】
activate "培训管理页面"
用户 -> "培训管理页面": 选择培训项目，设置问卷
"培训管理页面" -> "后端服务": 提交评估请求\n(携带评估数据)
activate "后端服务"
"后端服务" -> "数据库": 插入评估记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "后端服务": 发送评估通知\n(邮件/短信)
"后端服务" --> "培训管理页面": 返回成功响应
deactivate "后端服务"
"培训管理页面" --> 用户: 显示发起成功\n刷新列表
deactivate "培训管理页面"

== 填写评估流程 ==

用户 -> "培训管理页面": 点击【填写评估】按钮
activate "培训管理页面"
"培训管理页面" -> "后端服务": 请求评估问卷
activate "后端服务"
"后端服务" -> "数据库": 查询评估问卷
activate "数据库"
"数据库" --> "后端服务": 返回问卷数据
deactivate "数据库"
"后端服务" --> "培训管理页面": 返回问卷内容
deactivate "后端服务"
"培训管理页面" --> 用户: 展示评估问卷
deactivate "培训管理页面"

用户 -> "培训管理页面": 填写问卷，点击【提交】
activate "培训管理页面"
"培训管理页面" -> "后端服务": 提交评估答案
activate "后端服务"
"后端服务" -> "数据库": 保存评估答案
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" --> "培训管理页面": 返回成功响应
deactivate "后端服务"
"培训管理页面" --> 用户: 显示提交成功
deactivate "培训管理页面"

@enduml
