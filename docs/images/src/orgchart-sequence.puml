@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "组织架构图页面"
participant "后端服务"
database "数据库"

== 加载架构图 ==

用户 -> "组织架构图页面": 进入组织架构图页面
activate "组织架构图页面"
"组织架构图页面" -> "后端服务": 请求部门树形数据\n(默认按部门维度)
activate "后端服务"
"后端服务" -> "数据库": 查询全量部门层级数据\n及负责人、在编人数
activate "数据库"
"数据库" --> "后端服务": 返回部门树形结构数据
deactivate "数据库"
"后端服务" --> "组织架构图页面": 返回树形数据
deactivate "后端服务"
"组织架构图页面" --> 用户: 渲染组织架构树形图\n展示部门节点信息
deactivate "组织架构图页面"

== 切换查看维度 ==

用户 -> "组织架构图页面": 选择【按岗位】维度
activate "组织架构图页面"
"组织架构图页面" -> "后端服务": 请求岗位分布数据
activate "后端服务"
"后端服务" -> "数据库": 查询岗位及归属部门数据
activate "数据库"
"数据库" --> "后端服务": 返回岗位树形结构数据
deactivate "数据库"
"后端服务" --> "组织架构图页面": 返回岗位数据
deactivate "后端服务"
"组织架构图页面" --> 用户: 切换展示岗位架构图
deactivate "组织架构图页面"

== 展开/折叠节点 ==

用户 -> "组织架构图页面": 点击节点展开/折叠图标
activate "组织架构图页面"
"组织架构图页面" --> 用户: 展开或收起对应子节点\n实时更新树形图显示
deactivate "组织架构图页面"

== 导出架构图 ==

用户 -> "组织架构图页面": 点击【导出】，选择导出格式\n(PDF 或 图片)
activate "组织架构图页面"
"组织架构图页面" -> "后端服务": 提交导出请求\n(携带当前维度和格式参数)
activate "后端服务"
"后端服务" -> "数据库": 查询完整架构图数据
activate "数据库"
"数据库" --> "后端服务": 返回完整数据
deactivate "数据库"
"后端服务" --> "组织架构图页面": 返回生成的文件流
deactivate "后端服务"
"组织架构图页面" --> 用户: 触发文件下载\n保存至本地
deactivate "组织架构图页面"

@enduml
