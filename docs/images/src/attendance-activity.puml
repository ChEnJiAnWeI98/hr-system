@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入考勤管理页面;
:查看考勤功能模块;

:选择操作;

if (操作类型?) then (考勤规则配置)
  :查看考勤规则列表;
  if (子操作?) then (新增考勤规则)
    :点击【新增规则】按钮;
    :填写规则信息;
    :设置考勤时间;
    :设置打卡要求;
    :点击【保存】;
    if (数据验证?) then (验证通过)
      :保存成功\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (编辑考勤规则)
    :点击【编辑】按钮;
    :修改规则信息;
    :保存成功\n刷新列表;
  else (删除考勤规则)
    :点击【删除】按钮;
    :二次确认弹窗;
    if (确认?) then (确认)
      :删除成功\n刷新列表;
    else (取消)
      stop
    endif
  endif
elseif (操作类型?) then (打卡管理)
  :查看打卡记录列表;
  if (子操作?) then (手动打卡)
    :点击【打卡】按钮;
    :选择打卡类型;
    :获取定位信息;
    :点击【确认打卡】;
    :打卡成功\n刷新列表;
  elseif (子操作?) then (补卡申请)
    :点击【补卡申请】按钮;
    :选择补卡日期;
    :填写补卡原因;
    :上传证明材料;
    :点击【提交】;
    if (数据验证?) then (验证通过)
      :提交成功\n发起审批流程\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  else (查看打卡详情)
    :点击【查看详情】按钮;
    :查看打卡时间;
    :查看打卡地点;
    :查看打卡照片;
  endif
elseif (操作类型?) then (加班管理)
  :查看加班申请列表;
  if (子操作?) then (提交加班申请)
    :点击【加班申请】按钮;
    :选择加班日期;
    :选择加班时段;
    :填写加班事由;
    :点击【提交】;
    if (数据验证?) then (验证通过)
      :提交成功\n发起审批流程\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (撤回加班申请)
    :点击【撤回】按钮;
    :二次确认弹窗;
    if (确认撤回?) then (确认)
      :撤回成功\n刷新列表;
    else (取消)
      stop
    endif
  else (查看加班详情)
    :点击【查看详情】按钮;
    :查看加班信息;
    :查看审批进度;
    :查看审批历史;
  endif
elseif (操作类型?) then (外勤管理)
  :查看外勤记录列表;
  if (子操作?) then (提交外勤申请)
    :点击【外勤申请】按钮;
    :选择外勤日期;
    :填写外勤地点;
    :填写外勤事由;
    :点击【提交】;
    if (数据验证?) then (验证通过)
      :提交成功\n发起审批流程\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (外勤打卡)
    :点击【外勤打卡】按钮;
    :获取GPS定位;
    :拍摄现场照片;
    :点击【确认打卡】;
    :打卡成功\n刷新列表;
  else (查看外勤轨迹)
    :点击【查看轨迹】按钮;
    :查看外勤路线;
    :查看打卡位置;
    :查看时间记录;
  endif
else (考勤统计)
  :查看考勤统计报表;
  if (子操作?) then (查看个人考勤)
    :点击【个人考勤】按钮;
    :查看出勤天数;
    :查看迟到早退次数;
    :查看加班时长;
    :查看异常记录;
  elseif (子操作?) then (查看部门考勤)
    :点击【部门考勤】按钮;
    :选择部门;
    :选择统计月份;
    :查看部门出勤率;
    :查看异常统计;
  else (导出考勤报表)
    :点击【导出】按钮;
    :选择导出格式;
    :选择导出范围;
    :下载考勤报表文件;
  endif
endif

stop

@enduml
