@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "证件管理页面"
participant "后端服务"
database "数据库"
participant "定时任务"

== 定时扫描证件到期流程 ==

"定时任务" -> "后端服务": 每天凌晨2点触发扫描任务
activate "后端服务"
"后端服务" -> "数据库": 查询即将到期的证件\n(提前90/60/30/15/7/3/0天)
activate "数据库"
"数据库" --> "后端服务": 返回到期证件列表
deactivate "数据库"

alt 有即将到期的证件
  "后端服务" -> "数据库": 插入提醒记录
  activate "数据库"
  "数据库" --> "后端服务": 记录插入成功
  deactivate "数据库"
  "后端服务" -> "数据库": 发送系统消息
  activate "数据库"
  "数据库" --> "后端服务": 消息发送成功
  deactivate "数据库"
  "后端服务" -> "数据库": 发送邮件通知
  activate "数据库"
  "数据库" --> "后端服务": 邮件发送成功
  deactivate "数据库"
  "后端服务" -> "数据库": 发送企业微信通知
  activate "数据库"
  "数据库" --> "后端服务": 企业微信通知成功
  deactivate "数据库"
else 无即将到期的证件
  "后端服务" -> "数据库": 记录扫描日志
  activate "数据库"
  "数据库" --> "后端服务": 日志记录成功
  deactivate "数据库"
end
deactivate "后端服务"

== 查看到期证件列表流程 ==

用户 -> "证件管理页面": 进入证件管理页面
activate "证件管理页面"
"证件管理页面" -> "后端服务": 请求到期证件列表\n(携带筛选条件)
activate "后端服务"
"后端服务" -> "数据库": 查询到期证件
activate "数据库"
"数据库" --> "后端服务": 返回证件列表
deactivate "数据库"
"后端服务" --> "证件管理页面": 返回列表数据
deactivate "后端服务"
"证件管理页面" --> 用户: 展示到期证件列表\n(按到期时间排序)
deactivate "证件管理页面"

== 联系员工更新证件流程 ==

用户 -> "证件管理页面": 点击【联系员工】按钮
activate "证件管理页面"
"证件管理页面" -> "后端服务": 发送提醒消息给员工
activate "后端服务"
"后端服务" -> "数据库": 插入提醒记录
activate "数据库"
"数据库" --> "后端服务": 记录插入成功
deactivate "数据库"
"后端服务" -> "数据库": 发送通知给员工
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" -> "数据库": 更新提醒状态为"已联系"
activate "数据库"
"数据库" --> "后端服务": 状态更新成功
deactivate "数据库"
"后端服务" --> "证件管理页面": 返回成功响应
deactivate "后端服务"
"证件管理页面" --> 用户: 显示"已联系员工"\n刷新列表
deactivate "证件管理页面"

== 更新证件信息流程 ==

用户 -> "证件管理页面": 点击【更新证件】按钮
activate "证件管理页面"
"证件管理页面" -> "后端服务": 请求证件详情
activate "后端服务"
"后端服务" -> "数据库": 查询证件信息
activate "数据库"
"数据库" --> "后端服务": 返回证件数据
deactivate "数据库"
"后端服务" --> "证件管理页面": 返回证件详情
deactivate "后端服务"
"证件管理页面" --> 用户: 打开更新表单\n回显证件信息
deactivate "证件管理页面"

用户 -> "证件管理页面": 填写新证件信息，上传扫描件
用户 -> "证件管理页面": 点击【保存】
activate "证件管理页面"
"证件管理页面" -> "后端服务": 提交更新请求\n(携带新证件信息)
activate "后端服务"
"后端服务" -> "数据库": 更新证件信息
activate "数据库"
"数据库" --> "后端服务": 更新成功
deactivate "数据库"
"后端服务" -> "数据库": 插入更新历史记录
activate "数据库"
"数据库" --> "后端服务": 记录插入成功
deactivate "数据库"
"后端服务" -> "数据库": 取消到期提醒
activate "数据库"
"数据库" --> "后端服务": 提醒取消成功
deactivate "数据库"
"后端服务" --> "证件管理页面": 返回成功响应
deactivate "后端服务"
"证件管理页面" --> 用户: 显示"更新成功"\n刷新列表
deactivate "证件管理页面"

== 延期处理流程 ==

用户 -> "证件管理页面": 点击【延期处理】按钮
activate "证件管理页面"
"证件管理页面" --> 用户: 打开延期处理表单
deactivate "证件管理页面"

用户 -> "证件管理页面": 填写延期原因和预计完成时间
用户 -> "证件管理页面": 点击【确认】
activate "证件管理页面"
"证件管理页面" -> "后端服务": 提交延期申请
activate "后端服务"
"后端服务" -> "数据库": 插入延期记录
activate "数据库"
"数据库" --> "后端服务": 记录插入成功
deactivate "数据库"
"后端服务" -> "数据库": 设置下次提醒时间
activate "数据库"
"数据库" --> "后端服务": 提醒时间设置成功
deactivate "数据库"
"后端服务" --> "证件管理页面": 返回成功响应
deactivate "后端服务"
"证件管理页面" --> 用户: 显示"延期成功"\n刷新列表
deactivate "证件管理页面"

== 查看证件详情流程 ==

用户 -> "证件管理页面": 点击【查看详情】按钮
activate "证件管理页面"
"证件管理页面" -> "后端服务": 请求证件完整信息
activate "后端服务"
"后端服务" -> "数据库": 查询证件详情
activate "数据库"
"数据库" --> "后端服务": 返回证件数据
deactivate "数据库"
"后端服务" -> "数据库": 查询更新历史
activate "数据库"
"数据库" --> "后端服务": 返回历史记录
deactivate "数据库"
"后端服务" --> "证件管理页面": 返回完整数据
deactivate "后端服务"
"证件管理页面" --> 用户: 展示证件详情页
deactivate "证件管理页面"

== 导出证件报表流程 ==

用户 -> "证件管理页面": 点击【导出】按钮
activate "证件管理页面"
"证件管理页面" -> "后端服务": 请求导出数据
activate "后端服务"
"后端服务" -> "数据库": 查询证件数据
activate "数据库"
"数据库" --> "后端服务": 返回证件数据
deactivate "数据库"
"后端服务" -> "后端服务": 生成Excel报表
"后端服务" --> "证件管理页面": 返回文件下载链接
deactivate "后端服务"
"证件管理页面" --> 用户: 触发文件下载
deactivate "证件管理页面"

@enduml
