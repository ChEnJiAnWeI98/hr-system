@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "假勤管理页面"
participant "后端服务"
database "数据库"

== 查看假期类型列表流程 ==

用户 -> "假勤管理页面": 进入假期配置管理
activate "假勤管理页面"
"假勤管理页面" -> "后端服务": 请求假期类型列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询假期类型数据
activate "数据库"
"数据库" --> "后端服务": 返回类型列表
deactivate "数据库"
"后端服务" --> "假勤管理页面": 返回列表数据
deactivate "后端服务"
"假勤管理页面" --> 用户: 展示假期类型列表
deactivate "假勤管理页面"

== 新增假期类型流程 ==

用户 -> "假勤管理页面": 点击【新增假期类型】，填写信息
用户 -> "假勤管理页面": 点击【保存】
activate "假勤管理页面"
"假勤管理页面" -> "后端服务": 提交新增请求\n(携带假期类型数据)
activate "后端服务"
"后端服务" -> "数据库": 插入假期类型记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "假勤管理页面": 返回成功响应
deactivate "后端服务"
"假勤管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "假勤管理页面"

== 发放假期额度流程 ==

用户 -> "假勤管理页面": 点击【发放额度】，选择员工和假期类型
用户 -> "假勤管理页面": 输入发放天数，点击【确认】
activate "假勤管理页面"
"假勤管理页面" -> "后端服务": 提交发放请求\n(携带员工ID、假期类型、天数)
activate "后端服务"
"后端服务" -> "数据库": 查询员工信息
activate "数据库"
"数据库" --> "后端服务": 返回员工信息
deactivate "数据库"
"后端服务" -> "数据库": 查询假期类型配置
activate "数据库"
"数据库" --> "后端服务": 返回假期配置
deactivate "数据库"
"后端服务" -> "数据库": 插入假期额度记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "假勤管理页面": 返回成功响应
deactivate "后端服务"
"假勤管理页面" --> 用户: 显示发放成功\n刷新列表
deactivate "假勤管理页面"

== 提交请假申请流程 ==

用户 -> "假勤管理页面": 点击【请假申请】，填写信息
用户 -> "假勤管理页面": 点击【提交】
activate "假勤管理页面"
"假勤管理页面" -> "后端服务": 提交请假申请\n(携带假期类型、时间、事由)
activate "后端服务"
"后端服务" -> "数据库": 查询员工假期额度
activate "数据库"
"数据库" --> "后端服务": 返回额度信息
deactivate "数据库"
"后端服务" -> "后端服务": 验证假期额度是否充足
"后端服务" -> "数据库": 插入请假申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请ID
deactivate "数据库"
"后端服务" -> "后端服务": 创建审批流程实例\n确定审批人
"后端服务" -> "后端服务": 发送审批通知
"后端服务" --> "假勤管理页面": 返回成功响应
deactivate "后端服务"
"假勤管理页面" --> 用户: 显示提交成功\n刷新列表
deactivate "假勤管理页面"

== 审批通过后处理流程 ==

用户 -> "假勤管理页面": 审批人审批通过请假申请
activate "假勤管理页面"
"假勤管理页面" -> "后端服务": 提交审批结果
activate "后端服务"
"后端服务" -> "数据库": 更新申请状态为已通过
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 扣减员工假期额度
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 插入假期使用记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "后端服务": 发送审批结果通知
"后端服务" --> "假勤管理页面": 返回成功响应
deactivate "后端服务"
"假勤管理页面" --> 用户: 显示审批成功\n刷新列表
deactivate "假勤管理页面"

== 生成调休额度流程 ==

用户 -> "假勤管理页面": 点击【生成调休】，选择加班记录
用户 -> "假勤管理页面": 选择转换比例，点击【确认】
activate "假勤管理页面"
"假勤管理页面" -> "后端服务": 提交生成调休请求\n(携带加班记录ID、转换比例)
activate "后端服务"
"后端服务" -> "数据库": 查询加班记录详情
activate "数据库"
"数据库" --> "后端服务": 返回加班记录
deactivate "数据库"
"后端服务" -> "后端服务": 计算调休天数\n(加班时长 × 转换比例)
"后端服务" -> "数据库": 插入调休额度记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 更新加班记录状态为已转调休
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "假勤管理页面": 返回调休数据
deactivate "后端服务"
"假勤管理页面" --> 用户: 显示生成成功\n展示调休额度
deactivate "假勤管理页面"

== 查看假期台账流程 ==

用户 -> "假勤管理页面": 点击【查看台账】，选择员工
activate "假勤管理页面"
"假勤管理页面" -> "后端服务": 请求假期台账数据\n(携带员工ID、时间范围)
activate "后端服务"
"后端服务" -> "数据库": 查询假期额度记录
activate "数据库"
"数据库" --> "后端服务": 返回额度记录
deactivate "数据库"
"后端服务" -> "数据库": 查询请假使用记录
activate "数据库"
"数据库" --> "后端服务": 返回使用记录
deactivate "数据库"
"后端服务" -> "后端服务": 计算剩余额度\n汇总台账数据
"后端服务" --> "假勤管理页面": 返回台账数据
deactivate "后端服务"
"假勤管理页面" --> 用户: 展示假期台账\n显示额度、使用、剩余
deactivate "假勤管理页面"

@enduml
