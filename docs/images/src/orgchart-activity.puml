@startuml
skinparam backgroundColor #FFFFFF
skinparam activityBackgroundColor #e3f2fd
skinparam activityBorderColor #90CAF9
skinparam activityDiamondBackgroundColor #fff3e0
skinparam activityDiamondBorderColor #FFCC80
skinparam activityStartColor #4CAF50
skinparam activityEndColor #4CAF50
skinparam ArrowColor #546E7A
skinparam activityFontSize 13
skinparam defaultFontName Microsoft YaHei

start

:进入组织架构图页面;

:系统加载并展示\n默认部门维度架构图;

fork
  :选择查看维度;
  if (选择维度？) then (按部门)
    :切换为部门树形架构图\n显示各级部门节点;
  else (按岗位)
    :切换为岗位树形架构图\n显示各岗位分布;
  endif
fork again
  :节点展开/折叠操作;
  if (节点操作？) then (点击折叠)
    :收起子节点\n仅显示当前层级;
  else (点击展开)
    :展开子节点\n显示下级组织结构;
  endif
end fork

:查看节点信息\n（部门名称 / 负责人 / 在编人数）;

if (是否导出？) then (是)
  :选择导出格式;
  if (导出格式？) then (PDF)
    :系统生成 PDF 文件\n弹出下载提示;
  else (图片)
    :系统生成图片文件\n弹出下载提示;
  endif
  :文件下载至本地;
else (否)
  :继续浏览架构图;
endif

stop
@enduml
