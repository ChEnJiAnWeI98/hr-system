@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入假勤管理页面;
:查看假勤功能模块;

:选择操作;

if (操作类型?) then (假期配置)
  :查看假期类型列表;
  if (子操作?) then (新增假期类型)
    :点击【新增假期类型】按钮;
    :填写假期名称;
    :选择假期类别;
    :设置计算规则;
    :点击【保存】;
    if (数据验证?) then (验证通过)
      :保存成功\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (编辑假期类型)
    :点击【编辑】按钮;
    :修改假期信息;
    :保存成功\n刷新列表;
  else (删除假期类型)
    :点击【删除】按钮;
    :二次确认弹窗;
    if (确认?) then (确认)
      :删除成功\n刷新列表;
    else (取消)
      stop
    endif
  endif
elseif (操作类型?) then (假期额度管理)
  :查看员工假期额度列表;
  if (子操作?) then (发放假期额度)
    :点击【发放额度】按钮;
    :选择员工范围;
    :选择假期类型;
    :输入发放天数;
    :选择生效日期;
    :额度发放成功;
  elseif (子操作?) then (调整假期额度)
    :点击【调整额度】按钮;
    :选择调整员工;
    :输入调整天数;
    :填写调整原因;
    :额度调整成功;
  else (查看额度明细)
    :点击【查看明细】按钮;
    :查看发放记录;
    :查看使用记录;
    :查看剩余额度;
  endif
elseif (操作类型?) then (请假申请)
  :查看请假申请列表;
  if (子操作?) then (提交请假申请)
    :点击【请假申请】按钮;
    :选择假期类型;
    :选择请假时间;
    :填写请假事由;
    :上传附件;
    :点击【提交】;
    if (数据验证?) then (验证通过)
      :提交成功\n发起审批流程\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (撤销请假申请)
    :点击【撤销】按钮;
    :二次确认弹窗;
    if (确认撤销?) then (确认)
      :撤销成功\n刷新列表;
    else (取消)
      stop
    endif
  else (查看申请详情)
    :点击【查看详情】按钮;
    :查看请假信息;
    :查看审批流程;
    :查看审批意见;
  endif
elseif (操作类型?) then (调休管理)
  :查看调休列表;
  if (子操作?) then (生成调休额度)
    :点击【生成调休】按钮;
    :选择加班记录;
    :选择转换比例;
    :生成调休成功;
  elseif (子操作?) then (使用调休额度)
    :点击【使用调休】按钮;
    :选择调休时间;
    :填写调休事由;
    :提交调休申请成功;
  else (查看调休记录)
    :点击【查看记录】按钮;
    :查看调休生成记录;
    :查看调休使用记录;
    :查看调休余额;
  endif
else (假期台账)
  :查看假期台账列表;
  if (子操作?) then (查看员工假期台账)
    :点击【查看台账】按钮;
    :查看假期额度;
    :查看请假记录;
    :查看剩余额度;
  elseif (子操作?) then (导出假期台账)
    :点击【导出】按钮;
    :选择导出范围;
    :下载台账文件;
  else (假期统计分析)
    :点击【统计分析】按钮;
    :查看假期使用趋势;
    :查看部门假期对比;
    :查看假期类型分布;
  endif
endif

stop

@enduml
