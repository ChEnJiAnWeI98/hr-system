@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入员工自助页面;
:查看员工自助功能模块;

:选择操作;

if (操作类型?) then (个人信息管理)
  :查看个人信息;
  if (子操作?) then (修改个人信息)
    :点击【编辑】按钮;
    :修改可编辑字段;
    :点击【保存】;
    if (数据验证?) then (验证通过)
      :保存成功\n刷新页面;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (上传头像)
    :点击【上传头像】按钮;
    :选择图片文件;
    if (文件验证?) then (验证通过)
      :上传成功\n刷新页面;
    else (验证失败)
      :显示错误提示\n重新选择;
      detach
    endif
  else (查看详细信息)
    :查看基本信息;
    :查看教育经历;
    :查看工作经历;
  endif
elseif (操作类型?) then (工资条查询)
  :查看工资条列表;
  if (子操作?) then (查看工资详情)
    :点击【查看详情】按钮;
    :查看工资明细;
    :查看扣款明细;
    :查看实发工资;
  elseif (子操作?) then (下载工资条)
    :点击【下载】按钮;
    :选择下载格式;
    :下载工资条文件;
  else (导出工资条)
    :点击【导出】按钮;
    :选择导出月份范围;
    :下载导出文件;
  endif
elseif (操作类型?) then (假期余额查询)
  :查看假期余额列表;
  if (子操作?) then (查看假期明细)
    :点击【查看明细】按钮;
    :查看假期发放记录;
    :查看假期使用记录;
    :查看假期调整记录;
  elseif (子操作?) then (申请请假)
    :点击【申请请假】按钮;
    :选择请假类型;
    :选择请假时间;
    :填写请假事由;
    :上传请假附件;
    :点击【提交】;
    if (数据验证?) then (验证通过)
      :提交成功\n发起审批流程\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  else (查看请假记录)
    :查看请假申请列表;
    :查看审批进度;
    :查看审批历史;
  endif
elseif (操作类型?) then (申请管理)
  :查看我的申请列表;
  if (子操作?) then (提交新申请)
    :点击【新建申请】按钮;
    :选择申请类型;
    :填写申请表单;
    :上传附件;
    :点击【提交】;
    if (数据验证?) then (验证通过)
      :提交成功\n发起审批流程\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (撤回申请)
    :点击【撤回】按钮;
    :二次确认弹窗;
    if (确认撤回?) then (确认)
      :撤回成功\n刷新列表;
    else (取消)
      stop
    endif
  else (查看申请详情)
    :点击【查看详情】按钮;
    :查看申请信息;
    :查看审批进度;
    :查看审批意见;
  endif
else (待办任务)
  :查看待办任务列表;
  if (子操作?) then (处理待办)
    :点击【处理】按钮;
    :查看任务详情;
    :填写处理意见;
    :点击【提交】;
    :处理成功\n刷新列表;
  elseif (子操作?) then (查看任务详情)
    :点击【查看详情】按钮;
    :查看任务信息;
    :查看相关数据;
  else (标记已读)
    :点击【标记已读】按钮;
    :标记成功\n刷新列表;
  endif
endif

stop

@enduml
