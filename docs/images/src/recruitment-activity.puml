@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入招聘管理页面;
:查看招聘功能模块;

:选择操作;

if (操作类型?) then (招聘需求管理)
  :查看招聘需求列表;
  if (子操作?) then (新增需求)
    :点击【新增需求】按钮;
    :填写需求信息;
    :提交审批;
    if (审批结果?) then (通过)
      :需求生效\n刷新列表;
    else (驳回)
      :显示驳回原因\n修改需求;
      detach
    endif
  elseif (子操作?) then (编辑需求)
    :点击【编辑】按钮;
    :修改需求信息;
    :保存成功\n刷新列表;
  else (关闭需求)
    :点击【关闭】按钮;
    :确认关闭;
    :需求关闭\n刷新列表;
  endif
elseif (操作类型?) then (职位发布)
  :选择招聘需求;
  :点击【发布职位】按钮;
  :填写职位信息;
  :选择发布渠道;
  if (数据验证?) then (验证通过)
    :职位发布成功\n刷新列表;
  else (验证失败)
    :显示错误提示\n停留在表单;
    :重新填写;
    detach
  endif
elseif (操作类型?) then (简历管理)
  :查看简历列表;
  if (子操作?) then (筛选简历)
    :设置筛选条件;
    :查看筛选结果;
  elseif (子操作?) then (查看简历)
    :点击【查看详情】按钮;
    :查看简历详细信息;
    :添加评价标签;
  elseif (子操作?) then (推荐面试)
    :选择简历;
    :点击【推荐面试】按钮;
    :安排面试;
  else (淘汰简历)
    :选择简历;
    :点击【淘汰】按钮;
    :填写淘汰原因;
    :确认淘汰;
  endif
elseif (操作类型?) then (面试管理)
  :查看面试安排列表;
  if (子操作?) then (安排面试)
    :点击【安排面试】按钮;
    :选择候选人;
    :设置面试时间;
    :选择面试官;
    :发送面试通知;
    :面试安排成功\n刷新列表;
  elseif (子操作?) then (填写评价)
    :点击【填写评价】按钮;
    :填写面试评价;
    :给出面试结果;
    :保存评价\n刷新列表;
  else (调整面试)
    :点击【调整】按钮;
    :修改面试时间;
    :发送调整通知;
    :调整成功\n刷新列表;
  endif
elseif (操作类型?) then (Offer管理)
  :查看Offer列表;
  if (子操作?) then (发放Offer)
    :选择候选人;
    :点击【发放Offer】按钮;
    :填写Offer信息;
    :提交审批;
    if (审批结果?) then (通过)
      :发送Offer\n刷新列表;
    else (驳回)
      :显示驳回原因\n修改Offer;
      detach
    endif
  elseif (子操作?) then (查看Offer)
    :点击【查看详情】按钮;
    :查看Offer详细信息;
    :查看候选人反馈;
  else (撤回Offer)
    :点击【撤回】按钮;
    :填写撤回原因;
    :确认撤回;
    :Offer撤回\n刷新列表;
  endif
else (入职衔接)
  :查看待入职人员列表;
  if (子操作?) then (办理入职)
    :点击【办理入职】按钮;
    :填写入职信息;
    :上传入职资料;
    :分配部门岗位;
    :开通系统账号;
    :入职办理完成\n刷新列表;
  elseif (子操作?) then (入职提醒)
    :查看入职日期;
    :发送入职提醒;
  else (取消入职)
    :点击【取消入职】按钮;
    :填写取消原因;
    :确认取消;
    :入职取消\n刷新列表;
  endif
endif

stop

@enduml
