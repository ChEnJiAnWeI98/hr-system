@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center
skinparam swimlaneBackgroundColor #FAFAFA
skinparam ArrowColor #555555
skinparam ActivityBorderColor #888888

|HR管理员|
start
:进入试用期管理页面;

:查看试用期员工列表;
note right
  支持按部门、入职日期、
  转正日期等条件筛选
end note

if (选择操作?) then (发起转正评估)
  :点击【发起转正评估】;
  :选择试用期员工;
  :填写评估信息;
  note right
    评估内容、评估结果
    转正日期、薪资调整等
  end note
  :提交转正评估;
  |系统|
  :创建转正评估记录;
  :发送评估通知;
  |部门负责人|
  :收到评估通知;
  :查看员工试用期表现;
  :填写评估意见;
  if (是否通过?) then (通过)
    |HR管理员|
    :收到评估通过通知;
    :确认转正信息;
    note right
      转正日期、转正后薪资
      转正后岗位等
    end note
    :办理转正手续;
    |系统|
    :更新员工状态为"正式员工";
    :更新薪资信息;
    :发送转正通知;
    |员工|
    :收到转正确认通知;
    stop
  else (不通过)
    if (是否延长试用期?) then (延长)
      |HR管理员|
      :收到延长试用期通知;
      :确认延长期限;
      note right
        延长原因、延长时长
        新的转正日期
      end note
      |系统|
      :更新试用期结束日期;
      :发送延长通知;
      |员工|
      :收到试用期延长通知;
      stop
    else (不延长)
      |HR管理员|
      :收到不通过通知;
      :发起离职流程;
      note right
        试用期不合格
        办理离职手续
      end note
      stop
    endif
  endif

elseif (选择操作?) then (查看转正提醒)
  :点击【转正提醒】;
  |系统|
  :查询即将到期的试用期员工;
  note right
    提前30天、15天、7天
    自动提醒HR
  end note
  |HR管理员|
  :查看提醒列表;
  :标记已处理;
  stop

elseif (选择操作?) then (查看评估记录)
  :点击【查看评估记录】;
  |系统|
  :展示员工转正评估历史;
  note right
    评估时间、评估人
    评估结果、评估意见
  end note
  |HR管理员|
  :查看评估详情;
  if (需要导出?) then (是)
    :点击【导出】按钮;
    |系统|
    :生成评估报告;
    |HR管理员|
    :下载评估报告;
  else (否)
    :关闭详情页;
  endif
  stop

else (批量转正)
  :点击【批量转正】;
  :选择多个试用期员工;
  :确认转正信息;
  note right
    批量设置转正日期
    批量调整薪资
  end note
  |系统|
  :批量更新员工状态;
  :批量更新薪资信息;
  :批量发送转正通知;
  |HR管理员|
  :系统显示批量转正成功;
  stop
endif

@enduml
