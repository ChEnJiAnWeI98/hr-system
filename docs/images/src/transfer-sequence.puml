@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "员工异动页面"
participant "后端服务"
database "数据库"

== 查看异动申请列表流程 ==

用户 -> "员工异动页面": 进入员工异动页面
activate "员工异动页面"
"员工异动页面" -> "后端服务": 请求异动申请列表\n(携带筛选条件)
activate "后端服务"
"后端服务" -> "数据库": 查询异动申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请列表
deactivate "数据库"
"后端服务" --> "员工异动页面": 返回列表数据
deactivate "后端服务"
"员工异动页面" --> 用户: 展示异动申请列表
deactivate "员工异动页面"

== 发起异动申请流程 ==

用户 -> "员工异动页面": 点击【发起异动】按钮
activate "员工异动页面"
"员工异动页面" --> 用户: 打开异动申请表单
deactivate "员工异动页面"

用户 -> "员工异动页面": 填写异动信息，点击【提交】
activate "员工异动页面"
"员工异动页面" -> "后端服务": 提交异动申请\n(携带异动信息)
activate "后端服务"
"后端服务" -> "数据库": 插入异动申请记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 创建审批流程
activate "数据库"
"数据库" --> "后端服务": 返回流程ID
deactivate "数据库"
"后端服务" -> "数据库": 发送审批通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "员工异动页面": 返回成功响应
deactivate "后端服务"
"员工异动页面" --> 用户: 显示"提交成功"\n刷新列表
deactivate "员工异动页面"

== 部门负责人审批流程 ==

用户 -> "员工异动页面": 点击【审批】按钮
activate "员工异动页面"
"员工异动页面" -> "后端服务": 请求异动申请详情
activate "后端服务"
"后端服务" -> "数据库": 查询申请详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "员工异动页面": 返回详情数据
deactivate "后端服务"
"员工异动页面" --> 用户: 打开审批弹窗\n回显申请信息
deactivate "员工异动页面"

用户 -> "员工异动页面": 填写审批意见，点击【通过】或【拒绝】
activate "员工异动页面"
"员工异动页面" -> "后端服务": 提交审批结果
activate "后端服务"
"后端服务" -> "数据库": 更新审批状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 插入审批记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 发送审批结果通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "员工异动页面": 返回成功响应
deactivate "后端服务"
"员工异动页面" --> 用户: 显示"审批成功"\n刷新列表
deactivate "员工异动页面"

== HR审核并生效流程 ==

用户 -> "员工异动页面": 点击【HR审核】按钮
activate "员工异动页面"
"员工异动页面" -> "后端服务": 请求异动申请详情
activate "后端服务"
"后端服务" -> "数据库": 查询申请详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "员工异动页面": 返回详情数据
deactivate "后端服务"
"员工异动页面" --> 用户: 打开审核弹窗\n回显申请信息
deactivate "员工异动页面"

用户 -> "员工异动页面": 确认生效日期，点击【通过】
activate "员工异动页面"
"员工异动页面" -> "后端服务": 提交审核结果
activate "后端服务"
"后端服务" -> "数据库": 更新审核状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 更新员工档案
activate "数据库"
"数据库" --> "后端服务": 档案更新成功
deactivate "数据库"
"后端服务" -> "数据库": 插入异动历史记录
activate "数据库"
"数据库" --> "后端服务": 记录插入成功
deactivate "数据库"
"后端服务" -> "数据库": 发送异动通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "员工异动页面": 返回成功响应
deactivate "后端服务"
"员工异动页面" --> 用户: 显示"异动已生效"\n刷新列表
deactivate "员工异动页面"

== 查看异动历史流程 ==

用户 -> "员工异动页面": 点击【查看异动历史】按钮
activate "员工异动页面"
"员工异动页面" -> "后端服务": 请求员工异动历史
activate "后端服务"
"后端服务" -> "数据库": 查询异动历史记录
activate "数据库"
"数据库" --> "后端服务": 返回历史数据
deactivate "数据库"
"后端服务" --> "员工异动页面": 返回历史数据
deactivate "后端服务"
"员工异动页面" --> 用户: 展示异动历史列表
deactivate "员工异动页面"

@enduml
