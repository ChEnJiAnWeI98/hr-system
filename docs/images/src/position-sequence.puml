@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "岗位管理页面"
participant "后端服务"
database "数据库"

== 查看岗位列表（含筛选） ==

用户 -> "岗位管理页面": 进入岗位管理页面
activate "岗位管理页面"
"岗位管理页面" -> "后端服务": 请求岗位列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询岗位数据
activate "数据库"
"数据库" --> "后端服务": 返回岗位列表
deactivate "数据库"
"后端服务" --> "岗位管理页面": 返回列表数据
deactivate "后端服务"
"岗位管理页面" --> 用户: 展示岗位列表
deactivate "岗位管理页面"

用户 -> "岗位管理页面": 选择部门/职级筛选条件，点击【查询】
activate "岗位管理页面"
"岗位管理页面" -> "后端服务": 请求筛选后岗位列表\n(携带筛选参数)
activate "后端服务"
"后端服务" -> "数据库": 按条件查询岗位数据
activate "数据库"
"数据库" --> "后端服务": 返回筛选结果
deactivate "数据库"
"后端服务" --> "岗位管理页面": 返回筛选后列表
deactivate "后端服务"
"岗位管理页面" --> 用户: 展示筛选结果
deactivate "岗位管理页面"

== 新增岗位（含名称重复校验） ==

用户 -> "岗位管理页面": 点击【新增岗位】，填写表单\n(名称、部门、类别、职级职等、说明书)
用户 -> "岗位管理页面": 点击【保存】
activate "岗位管理页面"
"岗位管理页面" -> "后端服务": 提交新增请求\n(携带岗位表单数据)
activate "后端服务"
"后端服务" -> "数据库": 检查岗位名称是否已存在
activate "数据库"
"数据库" --> "后端服务": 返回检查结果
deactivate "数据库"

alt 岗位名称重复
  "后端服务" --> "岗位管理页面": 返回名称重复错误
  deactivate "后端服务"
  "岗位管理页面" --> 用户: 提示"岗位名称已存在，请重新填写"
else 岗位名称不重复
  "后端服务" -> "数据库": 插入岗位记录
  activate "数据库"
  "数据库" --> "后端服务": 返回插入结果
  deactivate "数据库"
  "后端服务" --> "岗位管理页面": 返回成功响应
  deactivate "后端服务"
  "岗位管理页面" --> 用户: 显示"新增成功"\n刷新岗位列表
end
deactivate "岗位管理页面"

== 编辑岗位 ==

用户 -> "岗位管理页面": 点击某岗位的【编辑】按钮
activate "岗位管理页面"
"岗位管理页面" -> "后端服务": 请求岗位详情
activate "后端服务"
"后端服务" -> "数据库": 查询岗位详情
activate "数据库"
"数据库" --> "后端服务": 返回岗位详情数据
deactivate "数据库"
"后端服务" --> "岗位管理页面": 返回详情数据
deactivate "后端服务"
"岗位管理页面" --> 用户: 打开编辑弹窗\n回显岗位数据
deactivate "岗位管理页面"

用户 -> "岗位管理页面": 修改岗位信息，点击【保存】
activate "岗位管理页面"
"岗位管理页面" -> "后端服务": 提交更新请求\n(携带修改后数据)
activate "后端服务"
"后端服务" -> "数据库": 更新岗位记录
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "岗位管理页面": 返回成功响应
deactivate "后端服务"
"岗位管理页面" --> 用户: 显示"编辑成功"\n刷新岗位列表
deactivate "岗位管理页面"

== 停用岗位（含在职员工检查） ==

用户 -> "岗位管理页面": 选择【启用中】岗位，点击【停用】
activate "岗位管理页面"
"岗位管理页面" --> 用户: 弹出确认对话框
用户 -> "岗位管理页面": 确认停用
"岗位管理页面" -> "后端服务": 提交停用请求
activate "后端服务"
"后端服务" -> "数据库": 查询该岗位在职员工数量
activate "数据库"
"数据库" --> "后端服务": 返回在职员工数量
deactivate "数据库"

alt 存在在职员工
  "后端服务" --> "岗位管理页面": 返回不可停用错误
  deactivate "后端服务"
  "岗位管理页面" --> 用户: 提示"该岗位下存在在职员工，无法停用"
else 无在职员工
  "后端服务" -> "数据库": 更新岗位状态为【已停用】
  activate "数据库"
  "数据库" --> "后端服务": 返回更新结果
  deactivate "数据库"
  "后端服务" --> "岗位管理页面": 返回成功响应
  deactivate "后端服务"
  "岗位管理页面" --> 用户: 显示"停用成功"\n岗位状态更新为【已停用】
end
deactivate "岗位管理页面"

@enduml
