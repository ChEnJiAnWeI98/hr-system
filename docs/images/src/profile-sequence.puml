@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "员工档案页面"
participant "后端服务"
database "数据库"

== 查看员工列表流程 ==

用户 -> "员工档案页面": 进入员工档案页面
activate "员工档案页面"
"员工档案页面" -> "后端服务": 请求员工列表\n(携带筛选条件)
activate "后端服务"
"后端服务" -> "数据库": 查询员工档案
activate "数据库"
"数据库" --> "后端服务": 返回员工列表
deactivate "数据库"
"后端服务" --> "员工档案页面": 返回列表数据
deactivate "后端服务"
"员工档案页面" --> 用户: 展示员工列表
deactivate "员工档案页面"

== 新增员工档案流程 ==

用户 -> "员工档案页面": 点击【新增员工】按钮
activate "员工档案页面"
"员工档案页面" --> 用户: 打开新增表单
deactivate "员工档案页面"

用户 -> "员工档案页面": 填写员工信息，点击【保存】
activate "员工档案页面"
"员工档案页面" -> "后端服务": 提交新增请求\n(携带员工信息)
activate "后端服务"
"后端服务" -> "数据库": 插入员工档案记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 插入教育经历记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 插入工作经历记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 插入证件信息记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "员工档案页面": 返回成功响应
deactivate "后端服务"
"员工档案页面" --> 用户: 显示"保存成功"\n刷新列表
deactivate "员工档案页面"

== 编辑员工档案流程 ==

用户 -> "员工档案页面": 点击【编辑】按钮
activate "员工档案页面"
"员工档案页面" -> "后端服务": 请求员工详情
activate "后端服务"
"后端服务" -> "数据库": 查询员工基本信息
activate "数据库"
"数据库" --> "后端服务": 返回基本信息
deactivate "数据库"
"后端服务" -> "数据库": 查询教育经历
activate "数据库"
"数据库" --> "后端服务": 返回教育经历
deactivate "数据库"
"后端服务" -> "数据库": 查询工作经历
activate "数据库"
"数据库" --> "后端服务": 返回工作经历
deactivate "数据库"
"后端服务" -> "数据库": 查询证件信息
activate "数据库"
"数据库" --> "后端服务": 返回证件信息
deactivate "数据库"
"后端服务" --> "员工档案页面": 返回完整档案数据
deactivate "后端服务"
"员工档案页面" --> 用户: 打开编辑表单\n回显数据
deactivate "员工档案页面"

用户 -> "员工档案页面": 修改信息，点击【保存】
activate "员工档案页面"
"员工档案页面" -> "后端服务": 提交更新请求
activate "后端服务"
"后端服务" -> "数据库": 更新员工档案
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "员工档案页面": 返回成功响应
deactivate "后端服务"
"员工档案页面" --> 用户: 显示"更新成功"\n刷新列表
deactivate "员工档案页面"

== 查看员工详情流程 ==

用户 -> "员工档案页面": 点击【查看详情】按钮
activate "员工档案页面"
"员工档案页面" -> "后端服务": 请求员工完整档案
activate "后端服务"
"后端服务" -> "数据库": 查询员工全部信息
activate "数据库"
"数据库" --> "后端服务": 返回完整档案数据
deactivate "数据库"
"后端服务" --> "员工档案页面": 返回详情数据
deactivate "后端服务"
"员工档案页面" --> 用户: 展示员工详情页
deactivate "员工档案页面"

== 导出员工档案流程 ==

用户 -> "员工档案页面": 点击【导出】按钮
activate "员工档案页面"
"员工档案页面" -> "后端服务": 请求导出数据
activate "后端服务"
"后端服务" -> "数据库": 查询员工档案数据
activate "数据库"
"数据库" --> "后端服务": 返回档案数据
deactivate "数据库"
"后端服务" -> "后端服务": 生成Excel/PDF文件
"后端服务" --> "员工档案页面": 返回文件下载链接
deactivate "后端服务"
"员工档案页面" --> 用户: 触发文件下载
deactivate "员工档案页面"

@enduml
