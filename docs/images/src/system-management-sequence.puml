@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "系统管理页面"
participant "后端服务"
database "数据库"

== 查看用户列表流程 ==

用户 -> "系统管理页面": 进入用户账号管理
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求用户列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询用户数据
activate "数据库"
"数据库" --> "后端服务": 返回用户列表
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回列表数据
deactivate "后端服务"
"系统管理页面" --> 用户: 展示用户列表
deactivate "系统管理页面"

== 新增用户流程 ==

用户 -> "系统管理页面": 点击【新增用户】，填写信息
用户 -> "系统管理页面": 点击【保存】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 提交新增请求\n(携带用户数据)
activate "后端服务"
"后端服务" -> "数据库": 插入用户记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回成功响应
deactivate "后端服务"
"系统管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "系统管理页面"

== 角色权限配置流程 ==

用户 -> "系统管理页面": 点击【角色权限管理】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求角色列表
activate "后端服务"
"后端服务" -> "数据库": 查询角色数据
activate "数据库"
"数据库" --> "后端服务": 返回角色列表
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回角色数据
deactivate "后端服务"
"系统管理页面" --> 用户: 展示角色列表
deactivate "系统管理页面"

用户 -> "系统管理页面": 点击【编辑权限】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求权限树
activate "后端服务"
"后端服务" -> "数据库": 查询菜单权限树
activate "数据库"
"数据库" --> "后端服务": 返回权限树数据
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回权限树
deactivate "后端服务"
"系统管理页面" --> 用户: 展示权限配置界面
deactivate "系统管理页面"

用户 -> "系统管理页面": 勾选权限，点击【保存】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 提交权限配置
activate "后端服务"
"后端服务" -> "数据库": 更新角色权限关联
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回成功响应
deactivate "后端服务"
"系统管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "系统管理页面"

== 数据字典管理流程 ==

用户 -> "系统管理页面": 点击【数据字典管理】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求字典分类列表
activate "后端服务"
"后端服务" -> "数据库": 查询字典分类
activate "数据库"
"数据库" --> "后端服务": 返回分类列表
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回分类数据
deactivate "后端服务"
"系统管理页面" --> 用户: 展示字典分类
deactivate "系统管理页面"

用户 -> "系统管理页面": 选择分类，查看字典项
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求字典项列表
activate "后端服务"
"后端服务" -> "数据库": 查询字典项
activate "数据库"
"数据库" --> "后端服务": 返回字典项列表
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回字典项数据
deactivate "后端服务"
"系统管理页面" --> 用户: 展示字典项列表
deactivate "系统管理页面"

用户 -> "系统管理页面": 点击【新增字典项】，填写信息
activate "系统管理页面"
"系统管理页面" -> "后端服务": 提交新增请求
activate "后端服务"
"后端服务" -> "数据库": 插入字典项记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回成功响应
deactivate "后端服务"
"系统管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "系统管理页面"

== 操作日志查询流程 ==

用户 -> "系统管理页面": 点击【操作日志】，设置查询条件
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求日志列表\n(携带查询条件)
activate "后端服务"
"后端服务" -> "数据库": 查询操作日志
activate "数据库"
"数据库" --> "后端服务": 返回日志列表
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回日志数据
deactivate "后端服务"
"系统管理页面" --> 用户: 展示日志列表
deactivate "系统管理页面"

用户 -> "系统管理页面": 点击【导出日志】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求导出日志
activate "后端服务"
"后端服务" -> "数据库": 查询日志数据
activate "数据库"
"数据库" --> "后端服务": 返回日志数据
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回Excel文件
deactivate "后端服务"
"系统管理页面" --> 用户: 下载日志文件
deactivate "系统管理页面"

== 消息通知配置流程 ==

用户 -> "系统管理页面": 点击【消息通知配置】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求通知配置
activate "后端服务"
"后端服务" -> "数据库": 查询通知配置
activate "数据库"
"数据库" --> "后端服务": 返回配置数据
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回配置数据
deactivate "后端服务"
"系统管理页面" --> 用户: 展示通知配置界面
deactivate "系统管理页面"

用户 -> "系统管理页面": 修改配置，点击【保存】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 提交配置更新
activate "后端服务"
"后端服务" -> "数据库": 更新通知配置
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回成功响应
deactivate "后端服务"
"系统管理页面" --> 用户: 显示成功提示
deactivate "系统管理页面"

== 系统参数设置流程 ==

用户 -> "系统管理页面": 点击【系统参数设置】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 请求系统参数
activate "后端服务"
"后端服务" -> "数据库": 查询系统参数
activate "数据库"
"数据库" --> "后端服务": 返回参数数据
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回参数数据
deactivate "后端服务"
"系统管理页面" --> 用户: 展示参数设置界面
deactivate "系统管理页面"

用户 -> "系统管理页面": 修改参数，上传Logo，点击【保存】
activate "系统管理页面"
"系统管理页面" -> "后端服务": 提交参数更新\n(包含文件上传)
activate "后端服务"
"后端服务" -> "数据库": 更新系统参数
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "系统管理页面": 返回成功响应
deactivate "后端服务"
"系统管理页面" --> 用户: 显示成功提示\n系统重新加载配置
deactivate "系统管理页面"

@enduml
