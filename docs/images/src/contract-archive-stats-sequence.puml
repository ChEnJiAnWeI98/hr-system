@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "合同管理页面"
participant "后端服务"
database "数据库"

== 查看到期提醒流程 ==

用户 -> "合同管理页面": 进入到期提醒页面
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求到期提醒列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询即将到期的合同\n(提前30/60/90天)
activate "数据库"
"数据库" --> "后端服务": 返回到期提醒列表
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回列表数据
deactivate "后端服务"
"合同管理页面" --> 用户: 展示到期提醒列表
deactivate "合同管理页面"

== 筛选到期提醒流程 ==

用户 -> "合同管理页面": 输入筛选条件\n(到期时间、员工姓名、部门)
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求筛选后的提醒列表
activate "后端服务"
"后端服务" -> "数据库": 按条件查询到期提醒
activate "数据库"
"数据库" --> "后端服务": 返回筛选结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回筛选后的列表
deactivate "后端服务"
"合同管理页面" --> 用户: 展示筛选结果
deactivate "合同管理页面"

== 查看归档合同流程 ==

用户 -> "合同管理页面": 进入合同归档页面
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求归档合同列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询已归档的合同
activate "数据库"
"数据库" --> "后端服务": 返回归档合同列表
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回列表数据
deactivate "后端服务"
"合同管理页面" --> 用户: 展示归档合同列表
deactivate "合同管理页面"

== 检索归档合同流程 ==

用户 -> "合同管理页面": 输入检索条件\n(合同编号、员工姓名、合同类型、归档时间)
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求检索结果
activate "后端服务"
"后端服务" -> "数据库": 按条件检索归档合同
activate "数据库"
"数据库" --> "后端服务": 返回检索结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回检索后的列表
deactivate "后端服务"
"合同管理页面" --> 用户: 展示检索结果
deactivate "合同管理页面"

== 查看归档合同详情流程 ==

用户 -> "合同管理页面": 点击【查看详情】
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同完整信息
activate "后端服务"
"后端服务" -> "数据库": 查询合同详情
activate "数据库"
"数据库" --> "后端服务": 返回合同数据
deactivate "数据库"
"后端服务" -> "数据库": 查询签订记录
activate "数据库"
"数据库" --> "后端服务": 返回签订记录
deactivate "数据库"
"后端服务" -> "数据库": 查询续签记录
activate "数据库"
"数据库" --> "后端服务": 返回续签记录
deactivate "数据库"
"后端服务" -> "数据库": 查询变更历史
activate "数据库"
"数据库" --> "后端服务": 返回变更历史
deactivate "数据库"
"后端服务" -> "数据库": 查询终止记录
activate "数据库"
"数据库" --> "后端服务": 返回终止记录
deactivate "数据库"
"后端服务" -> "数据库": 查询归档记录
activate "数据库"
"数据库" --> "后端服务": 返回归档记录
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回完整数据
deactivate "后端服务"
"合同管理页面" --> 用户: 打开详情页面\n显示合同完整信息\n提供文件下载功能
deactivate "合同管理页面"

== 手动归档合同流程 ==

用户 -> "合同管理页面": 选择已终止的合同\n点击【归档】按钮
activate "合同管理页面"
"合同管理页面" --> 用户: 打开归档确认弹窗
deactivate "合同管理页面"

用户 -> "合同管理页面": 确认归档
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交归档请求\n(携带合同ID)
activate "后端服务"
"后端服务" -> "数据库": 更新合同状态为"已归档"
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 创建归档记录
activate "数据库"
"数据库" --> "后端服务": 返回创建结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回归档成功响应
deactivate "后端服务"
"合同管理页面" --> 用户: 显示归档成功提示\n合同从列表移至归档列表
deactivate "合同管理页面"

== 查看统计报表流程 ==

用户 -> "合同管理页面": 进入合同统计页面
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求统计数据\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询合同到期统计数据
activate "数据库"
"数据库" --> "后端服务": 返回到期统计数据
deactivate "数据库"
"后端服务" -> "数据库": 查询合同类型分布数据
activate "数据库"
"数据库" --> "后端服务": 返回类型分布数据
deactivate "数据库"
"后端服务" -> "数据库": 查询续签率分析数据
activate "数据库"
"数据库" --> "后端服务": 返回续签率数据
deactivate "数据库"
"后端服务" -> "数据库": 查询合同数量趋势数据
activate "数据库"
"数据库" --> "后端服务": 返回趋势数据
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回统计报表数据
deactivate "后端服务"
"合同管理页面" --> 用户: 展示统计报表
deactivate "合同管理页面"

== 筛选统计数据流程 ==

用户 -> "合同管理页面": 输入筛选条件\n(时间范围、部门、合同类型)
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求筛选后的统计数据
activate "后端服务"
"后端服务" -> "数据库": 按条件重新计算统计数据
activate "数据库"
"数据库" --> "后端服务": 返回筛选后的统计数据
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回筛选后的报表数据
deactivate "后端服务"
"合同管理页面" --> 用户: 展示筛选后的统计报表
deactivate "合同管理页面"

== 批量导出数据流程 ==

用户 -> "合同管理页面": 选择需要导出的合同\n点击【批量导出】按钮
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交导出请求\n(携带合同ID列表)
activate "后端服务"
"后端服务" -> "后端服务": 验证导出数量\n(不超过1000条)
alt 验证失败
    "后端服务" --> "合同管理页面": 返回验证错误信息
    "合同管理页面" --> 用户: 显示错误提示
else 验证通过
    "后端服务" -> "数据库": 查询合同详细数据
    activate "数据库"
    "数据库" --> "后端服务": 返回合同数据
    deactivate "数据库"
    "后端服务" -> "后端服务": 生成Excel文件
    "后端服务" --> "合同管理页面": 返回文件下载链接
    deactivate "后端服务"
    "合同管理页面" --> 用户: 下载导出文件
    deactivate "合同管理页面"
end

== 定时任务自动归档流程 ==

"后端服务" -> "后端服务": 定时任务触发\n(每天凌晨1点)
activate "后端服务"
"后端服务" -> "数据库": 查询即将到期的合同\n(提前30/60/90天)
activate "数据库"
"数据库" --> "后端服务": 返回即将到期的合同列表
deactivate "数据库"
"后端服务" -> "后端服务": 生成提醒通知
"后端服务" -> "数据库": 保存提醒记录
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" -> "后端服务": 发送提醒通知\n(站内消息/邮件/短信)
"后端服务" -> "数据库": 查询已到期的合同
activate "数据库"
"数据库" --> "后端服务": 返回已到期的合同列表
deactivate "数据库"
"后端服务" -> "数据库": 更新合同状态为"已到期"
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 创建自动归档记录
activate "数据库"
"数据库" --> "后端服务": 返回创建结果
deactivate "数据库"
deactivate "后端服务"

@enduml
