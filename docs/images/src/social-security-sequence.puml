@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "社保管理页面"
participant "后端服务"
database "数据库"

== 查看参保配置列表流程 ==

用户 -> "社保管理页面": 进入参保配置管理
activate "社保管理页面"
"社保管理页面" -> "后端服务": 请求参保配置列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询参保配置数据
activate "数据库"
"数据库" --> "后端服务": 返回配置列表
deactivate "数据库"
"后端服务" --> "社保管理页面": 返回列表数据
deactivate "后端服务"
"社保管理页面" --> 用户: 展示参保配置列表
deactivate "社保管理页面"

== 新增参保配置流程 ==

用户 -> "社保管理页面": 点击【新增配置】，填写信息
用户 -> "社保管理页面": 点击【保存】
activate "社保管理页面"
"社保管理页面" -> "后端服务": 提交新增请求\n(携带配置数据)
activate "后端服务"
"后端服务" -> "数据库": 插入参保配置记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "社保管理页面": 返回成功响应
deactivate "后端服务"
"社保管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "社保管理页面"

== 新增参保流程 ==

用户 -> "社保管理页面": 点击【新增参保】，选择员工
用户 -> "社保管理页面": 填写参保信息，点击【提交】
activate "社保管理页面"
"社保管理页面" -> "后端服务": 提交参保申请\n(携带员工ID和参保数据)
activate "后端服务"
"后端服务" -> "数据库": 查询员工信息
activate "数据库"
"数据库" --> "后端服务": 返回员工信息
deactivate "数据库"
"后端服务" -> "数据库": 查询参保配置
activate "数据库"
"数据库" --> "后端服务": 返回参保配置
deactivate "数据库"
"后端服务" -> "后端服务": 计算缴纳金额
"后端服务" -> "数据库": 插入参保记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "社保管理页面": 返回成功响应
deactivate "后端服务"
"社保管理页面" --> 用户: 显示参保成功\n刷新列表
deactivate "社保管理页面"

== 停止参保流程 ==

用户 -> "社保管理页面": 点击【停止参保】，填写信息
用户 -> "社保管理页面": 点击【确认】
activate "社保管理页面"
"社保管理页面" -> "后端服务": 提交停保请求\n(携带停保数据)
activate "后端服务"
"后端服务" -> "数据库": 查询参保记录
activate "数据库"
"数据库" --> "后端服务": 返回参保记录
deactivate "数据库"
"后端服务" -> "数据库": 更新参保状态为已停保
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 插入停保记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "社保管理页面": 返回成功响应
deactivate "后端服务"
"社保管理页面" --> 用户: 显示停保成功\n刷新列表
deactivate "社保管理页面"

== 公积金基数调整流程 ==

用户 -> "社保管理页面": 点击【基数调整】，选择员工
用户 -> "社保管理页面": 输入新基数，点击【确认】
activate "社保管理页面"
"社保管理页面" -> "后端服务": 提交基数调整请求\n(携带调整数据)
activate "后端服务"
"后端服务" -> "数据库": 查询当前公积金记录
activate "数据库"
"数据库" --> "后端服务": 返回当前记录
deactivate "数据库"
"后端服务" -> "数据库": 更新公积金基数
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 插入调整历史记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "社保管理页面": 返回成功响应
deactivate "后端服务"
"社保管理页面" --> 用户: 显示调整成功\n刷新列表
deactivate "社保管理页面"

== 生成社保账单流程 ==

用户 -> "社保管理页面": 点击【生成账单】，选择月份
用户 -> "社保管理页面": 点击【确认】
activate "社保管理页面"
"社保管理页面" -> "后端服务": 提交生成账单请求\n(携带月份参数)
activate "后端服务"
"后端服务" -> "数据库": 查询参保员工列表
activate "数据库"
"数据库" --> "后端服务": 返回员工列表
deactivate "数据库"
"后端服务" -> "数据库": 查询参保配置
activate "数据库"
"数据库" --> "后端服务": 返回参保配置
deactivate "数据库"
"后端服务" -> "后端服务": 计算各项社保费用
"后端服务" -> "数据库": 插入账单记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "社保管理页面": 返回账单数据
deactivate "后端服务"
"社保管理页面" --> 用户: 显示账单生成成功\n展示账单详情
deactivate "社保管理页面"

== 生成申报表流程 ==

用户 -> "社保管理页面": 点击【生成申报表】，选择月份和类型
用户 -> "社保管理页面": 点击【确认】
activate "社保管理页面"
"社保管理页面" -> "后端服务": 提交生成申报表请求\n(携带月份和类型参数)
activate "后端服务"
"后端服务" -> "数据库": 查询参保数据
activate "数据库"
"数据库" --> "后端服务": 返回参保数据
deactivate "数据库"
"后端服务" -> "数据库": 查询缴纳记录
activate "数据库"
"数据库" --> "后端服务": 返回缴纳记录
deactivate "数据库"
"后端服务" -> "后端服务": 按申报格式组织数据
"后端服务" -> "数据库": 插入申报表记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "社保管理页面": 返回申报表数据
deactivate "后端服务"
"社保管理页面" --> 用户: 显示申报表生成成功\n支持预览和导出
deactivate "社保管理页面"

@enduml
