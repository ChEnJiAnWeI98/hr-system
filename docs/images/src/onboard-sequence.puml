@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "入职管理页面"
participant "后端服务"
database "数据库"

== 查看入职申请列表流程 ==

用户 -> "入职管理页面": 进入入职管理页面
activate "入职管理页面"
"入职管理页面" -> "后端服务": 请求入职申请列表\n(携带筛选条件)
activate "后端服务"
"后端服务" -> "数据库": 查询入职申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请列表
deactivate "数据库"
"后端服务" --> "入职管理页面": 返回列表数据
deactivate "后端服务"
"入职管理页面" --> 用户: 展示入职申请列表
deactivate "入职管理页面"

== 发起入职申请流程 ==

用户 -> "入职管理页面": 点击【发起入职】按钮
activate "入职管理页面"
"入职管理页面" --> 用户: 打开入职申请表单
deactivate "入职管理页面"

用户 -> "入职管理页面": 填写候选人信息，点击【提交】
activate "入职管理页面"
"入职管理页面" -> "后端服务": 提交入职申请\n(携带候选人信息)
activate "后端服务"
"后端服务" -> "数据库": 插入入职申请记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 创建审批流程
activate "数据库"
"数据库" --> "后端服务": 返回流程ID
deactivate "数据库"
"后端服务" -> "数据库": 发送审批通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "入职管理页面": 返回成功响应
deactivate "后端服务"
"入职管理页面" --> 用户: 显示"提交成功"\n刷新列表
deactivate "入职管理页面"

== 审批入职申请流程 ==

用户 -> "入职管理页面": 点击【审批】按钮
activate "入职管理页面"
"入职管理页面" -> "后端服务": 请求入职申请详情
activate "后端服务"
"后端服务" -> "数据库": 查询申请详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "入职管理页面": 返回详情数据
deactivate "后端服务"
"入职管理页面" --> 用户: 打开审批弹窗\n回显申请信息
deactivate "入职管理页面"

用户 -> "入职管理页面": 填写审批意见，点击【通过】或【拒绝】
activate "入职管理页面"
"入职管理页面" -> "后端服务": 提交审批结果
activate "后端服务"
"后端服务" -> "数据库": 更新审批状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 插入审批记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 发送审批结果通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "入职管理页面": 返回成功响应
deactivate "后端服务"
"入职管理页面" --> 用户: 显示"审批成功"\n刷新列表
deactivate "入职管理页面"

== 办理入职手续流程 ==

用户 -> "入职管理页面": 点击【办理入职】按钮
activate "入职管理页面"
"入职管理页面" -> "后端服务": 请求资料清单模板
activate "后端服务"
"后端服务" -> "数据库": 查询资料清单配置
activate "数据库"
"数据库" --> "后端服务": 返回清单数据
deactivate "数据库"
"后端服务" --> "入职管理页面": 返回清单数据
deactivate "后端服务"
"入职管理页面" --> 用户: 展示资料清单
deactivate "入职管理页面"

用户 -> "入职管理页面": 核对资料，点击【完成办理】
activate "入职管理页面"
"入职管理页面" -> "后端服务": 提交办理结果
activate "后端服务"
"后端服务" -> "数据库": 更新入职申请状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 创建员工档案
activate "数据库"
"数据库" --> "后端服务": 返回员工ID
deactivate "数据库"
"后端服务" -> "数据库": 生成员工工号
activate "数据库"
"数据库" --> "后端服务": 返回工号
deactivate "数据库"
"后端服务" -> "数据库": 创建系统账号
activate "数据库"
"数据库" --> "后端服务": 账号创建成功
deactivate "数据库"
"后端服务" -> "数据库": 发送欢迎邮件
activate "数据库"
"数据库" --> "后端服务": 邮件发送成功
deactivate "数据库"
"后端服务" --> "入职管理页面": 返回成功响应
deactivate "后端服务"
"入职管理页面" --> 用户: 显示"入职办理完成"\n刷新列表
deactivate "入职管理页面"

== 批量导入入职申请流程 ==

用户 -> "入职管理页面": 点击【批量导入】按钮
activate "入职管理页面"
"入职管理页面" -> "后端服务": 请求导入模板
activate "后端服务"
"后端服务" --> "入职管理页面": 返回Excel模板文件
deactivate "后端服务"
"入职管理页面" --> 用户: 下载模板文件
deactivate "入职管理页面"

用户 -> "入职管理页面": 上传填写好的Excel文件
activate "入职管理页面"
"入职管理页面" -> "后端服务": 提交Excel文件
activate "后端服务"
"后端服务" -> "后端服务": 解析Excel数据
"后端服务" -> "后端服务": 校验数据格式
alt 数据验证通过
  "后端服务" -> "数据库": 批量插入入职申请
  activate "数据库"
  "数据库" --> "后端服务": 返回插入结果
  deactivate "数据库"
  "后端服务" --> "入职管理页面": 返回成功响应
  "入职管理页面" --> 用户: 显示"导入成功"\n刷新列表
else 数据验证失败
  "后端服务" --> "入职管理页面": 返回错误信息
  "入职管理页面" --> 用户: 显示错误提示\n标注错误行
end
deactivate "后端服务"
deactivate "入职管理页面"

@enduml
