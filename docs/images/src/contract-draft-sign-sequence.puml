@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "合同起草页面"
participant "后端服务"
database "数据库"

== 查看待入职员工列表流程 ==

用户 -> "合同起草页面": 进入合同起草页面
activate "合同起草页面"
"合同起草页面" -> "后端服务": 请求待入职员工列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询待入职员工
activate "数据库"
"数据库" --> "后端服务": 返回员工列表
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回列表数据
deactivate "后端服务"
"合同起草页面" --> 用户: 展示待入职员工列表
deactivate "合同起草页面"

== 筛选员工流程 ==

用户 -> "合同起草页面": 输入筛选条件\n(员工姓名、部门、岗位)
activate "合同起草页面"
"合同起草页面" -> "后端服务": 请求筛选后的员工列表
activate "后端服务"
"后端服务" -> "数据库": 按条件查询员工
activate "数据库"
"数据库" --> "后端服务": 返回筛选结果
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回筛选后的列表
deactivate "后端服务"
"合同起草页面" --> 用户: 展示筛选结果
deactivate "合同起草页面"

== 起草合同流程 ==

用户 -> "合同起草页面": 选择员工，点击【起草合同】
activate "合同起草页面"
"合同起草页面" -> "后端服务": 请求合同模板列表
activate "后端服务"
"后端服务" -> "数据库": 查询可用合同模板
activate "数据库"
"数据库" --> "后端服务": 返回模板列表
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回模板数据
deactivate "后端服务"
"合同起草页面" --> 用户: 打开模板选择弹窗
deactivate "合同起草页面"

用户 -> "合同起草页面": 选择合同模板
activate "合同起草页面"
"合同起草页面" -> "后端服务": 请求生成合同草稿\n(携带员工ID和模板ID)
activate "后端服务"
"后端服务" -> "数据库": 查询员工档案数据
activate "数据库"
"数据库" --> "后端服务": 返回员工信息
deactivate "数据库"
"后端服务" -> "数据库": 查询模板内容
activate "数据库"
"数据库" --> "后端服务": 返回模板内容
deactivate "数据库"
"后端服务" -> "后端服务": 自动填充员工数据到模板
"后端服务" -> "数据库": 保存合同草稿
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回合同草稿数据
deactivate "后端服务"
"合同起草页面" --> 用户: 打开合同编辑页面\n展示自动填充后的内容
deactivate "合同起草页面"

== 编辑合同流程 ==

用户 -> "合同起草页面": 在线编辑合同内容
activate "合同起草页面"
"合同起草页面" -> "后端服务": 实时保存草稿\n(携带修改后的内容)
activate "后端服务"
"后端服务" -> "数据库": 更新合同草稿
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回保存成功响应
deactivate "后端服务"
"合同起草页面" --> 用户: 显示自动保存提示
deactivate "合同起草页面"

用户 -> "合同起草页面": 上传合同附件
activate "合同起草页面"
"合同起草页面" -> "后端服务": 上传附件文件
activate "后端服务"
"后端服务" -> "数据库": 保存附件信息
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回上传成功响应
deactivate "后端服务"
"合同起草页面" --> 用户: 显示附件上传成功
deactivate "合同起草页面"

== 提交审批流程 ==

用户 -> "合同起草页面": 点击【提交审批】
activate "合同起草页面"
"合同起草页面" -> "后端服务": 提交审批请求\n(携带合同草稿ID)
activate "后端服务"
"后端服务" -> "后端服务": 验证数据完整性和合规性
alt 验证失败
    "后端服务" --> "合同起草页面": 返回验证错误信息
    "合同起草页面" --> 用户: 显示错误提示
else 验证通过
    "后端服务" -> "数据库": 更新合同状态为"待审批"
    activate "数据库"
    "数据库" --> "后端服务": 返回更新结果
    deactivate "数据库"
    "后端服务" -> "数据库": 创建审批流程实例
    activate "数据库"
    "数据库" --> "后端服务": 返回流程实例ID
    deactivate "数据库"
    "后端服务" -> "后端服务": 发送审批通知
    "后端服务" --> "合同起草页面": 返回提交成功响应
    deactivate "后端服务"
    "合同起草页面" --> 用户: 显示提交成功提示\n合同进入审批流程
    deactivate "合同起草页面"
end

== 审批通过后签订流程 ==

用户 -> "合同起草页面": 进入合同签订页面
activate "合同起草页面"
"合同起草页面" -> "后端服务": 请求待签订合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询合同详情
activate "数据库"
"数据库" --> "后端服务": 返回合同数据
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回合同详情
deactivate "后端服务"
"合同起草页面" --> 用户: 展示合同内容
deactivate "合同起草页面"

用户 -> "合同起草页面": 选择签订方式\n填写签订信息
activate "合同起草页面"
用户 -> "合同起草页面": 点击【确认签订】
"合同起草页面" -> "后端服务": 提交签订请求\n(携带签订信息)
activate "后端服务"
"后端服务" -> "数据库": 记录签订信息
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" -> "数据库": 更新合同状态为"生效中"
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回签订成功响应
deactivate "后端服务"
"合同起草页面" --> 用户: 显示签订成功提示
deactivate "合同起草页面"

== 查看合同详情流程 ==

用户 -> "合同起草页面": 点击【查看详情】
activate "合同起草页面"
"合同起草页面" -> "后端服务": 请求合同完整信息
activate "后端服务"
"后端服务" -> "数据库": 查询合同详情和附件
activate "数据库"
"数据库" --> "后端服务": 返回完整数据
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回合同详情
deactivate "后端服务"
"合同起草页面" --> 用户: 打开详情页面\n展示合同信息
deactivate "合同起草页面"

用户 -> "合同起草页面": 点击【下载】
activate "合同起草页面"
"合同起草页面" -> "后端服务": 请求合同文件下载
activate "后端服务"
"后端服务" -> "数据库": 查询合同文件路径
activate "数据库"
"数据库" --> "后端服务": 返回文件路径
deactivate "数据库"
"后端服务" --> "合同起草页面": 返回文件下载链接
deactivate "后端服务"
"合同起草页面" --> 用户: 下载合同文件
deactivate "合同起草页面"

@enduml
