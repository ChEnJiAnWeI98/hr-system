@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "试用期管理页面"
participant "后端服务"
database "数据库"

== 查看试用期员工列表流程 ==

用户 -> "试用期管理页面": 进入试用期管理页面
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 请求试用期员工列表\n(携带筛选条件)
activate "后端服务"
"后端服务" -> "数据库": 查询试用期员工
activate "数据库"
"数据库" --> "后端服务": 返回员工列表
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回列表数据
deactivate "后端服务"
"试用期管理页面" --> 用户: 展示试用期员工列表
deactivate "试用期管理页面"

== 发起转正评估流程 ==

用户 -> "试用期管理页面": 点击【发起转正评估】按钮
activate "试用期管理页面"
"试用期管理页面" --> 用户: 打开转正评估表单
deactivate "试用期管理页面"

用户 -> "试用期管理页面": 填写评估信息，点击【提交】
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 提交转正评估\n(携带评估信息)
activate "后端服务"
"后端服务" -> "数据库": 插入转正评估记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 创建审批流程
activate "数据库"
"数据库" --> "后端服务": 返回流程ID
deactivate "数据库"
"后端服务" -> "数据库": 发送评估通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回成功响应
deactivate "后端服务"
"试用期管理页面" --> 用户: 显示"提交成功"\n刷新列表
deactivate "试用期管理页面"

== 部门负责人评估流程 ==

用户 -> "试用期管理页面": 点击【评估】按钮
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 请求员工试用期信息
activate "后端服务"
"后端服务" -> "数据库": 查询员工信息和试用期表现
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回详情数据
deactivate "后端服务"
"试用期管理页面" --> 用户: 打开评估弹窗\n回显员工信息
deactivate "试用期管理页面"

用户 -> "试用期管理页面": 填写评估意见，点击【通过】或【不通过】
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 提交评估结果
activate "后端服务"
"后端服务" -> "数据库": 更新评估状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 插入评估记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 发送评估结果通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回成功响应
deactivate "后端服务"
"试用期管理页面" --> 用户: 显示"评估成功"\n刷新列表
deactivate "试用期管理页面"

== 办理转正手续流程 ==

用户 -> "试用期管理页面": 点击【办理转正】按钮
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 请求转正信息
activate "后端服务"
"后端服务" -> "数据库": 查询评估结果
activate "数据库"
"数据库" --> "后端服务": 返回评估数据
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回转正信息
deactivate "后端服务"
"试用期管理页面" --> 用户: 展示转正确认信息
deactivate "试用期管理页面"

用户 -> "试用期管理页面": 确认转正信息，点击【确认转正】
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 提交转正确认
activate "后端服务"
"后端服务" -> "数据库": 更新员工状态为"正式员工"
activate "数据库"
"数据库" --> "后端服务": 状态更新成功
deactivate "数据库"
"后端服务" -> "数据库": 更新薪资信息
activate "数据库"
"数据库" --> "后端服务": 薪资更新成功
deactivate "数据库"
"后端服务" -> "数据库": 记录转正历史
activate "数据库"
"数据库" --> "后端服务": 记录插入成功
deactivate "数据库"
"后端服务" -> "数据库": 发送转正通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回成功响应
deactivate "后端服务"
"试用期管理页面" --> 用户: 显示"转正办理完成"\n刷新列表
deactivate "试用期管理页面"

== 延长试用期流程 ==

用户 -> "试用期管理页面": 点击【延长试用期】按钮
activate "试用期管理页面"
"试用期管理页面" --> 用户: 打开延长试用期表单
deactivate "试用期管理页面"

用户 -> "试用期管理页面": 填写延长原因和期限，点击【确认】
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 提交延长申请
activate "后端服务"
"后端服务" -> "数据库": 更新试用期结束日期
activate "数据库"
"数据库" --> "后端服务": 更新成功
deactivate "数据库"
"后端服务" -> "数据库": 记录延长历史
activate "数据库"
"数据库" --> "后端服务": 记录插入成功
deactivate "数据库"
"后端服务" -> "数据库": 发送延长通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回成功响应
deactivate "后端服务"
"试用期管理页面" --> 用户: 显示"延长成功"\n刷新列表
deactivate "试用期管理页面"

== 查看转正提醒流程 ==

用户 -> "试用期管理页面": 点击【转正提醒】按钮
activate "试用期管理页面"
"试用期管理页面" -> "后端服务": 请求即将到期的试用期员工
activate "后端服务"
"后端服务" -> "数据库": 查询即将到期员工\n(提前30天、15天、7天)
activate "数据库"
"数据库" --> "后端服务": 返回提醒列表
deactivate "数据库"
"后端服务" --> "试用期管理页面": 返回提醒数据
deactivate "后端服务"
"试用期管理页面" --> 用户: 展示转正提醒列表
deactivate "试用期管理页面"

@enduml
