@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入社保管理页面;
:查看社保功能模块;

:选择操作;

if (操作类型?) then (参保配置)
  :查看参保配置列表;
  if (子操作?) then (新增配置)
    :点击【新增配置】按钮;
    :选择城市;
    :设置社保基数;
    :设置缴纳比例;
    :点击【保存】;
    if (数据验证?) then (验证通过)
      :保存成功\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (编辑配置)
    :点击【编辑】按钮;
    :修改配置信息;
    :保存成功\n刷新列表;
  else (删除配置)
    :点击【删除】按钮;
    :二次确认弹窗;
    if (确认?) then (确认)
      :删除成功\n刷新列表;
    else (取消)
      stop
    endif
  endif
elseif (操作类型?) then (增减员管理)
  :查看增减员列表;
  if (子操作?) then (新增参保)
    :点击【新增参保】按钮;
    :选择员工;
    :选择参保类型;
    :设置参保日期;
    :填写参保信息;
    :提交成功\n刷新列表;
  elseif (子操作?) then (停止参保)
    :点击【停止参保】按钮;
    :选择停保日期;
    :填写停保原因;
    :二次确认弹窗;
    if (确认停保?) then (确认)
      :停保成功\n刷新列表;
    else (取消)
      stop
    endif
  else (查看详情)
    :点击【查看详情】按钮;
    :查看参保信息;
    :查看缴纳记录;
    :查看变更历史;
  endif
elseif (操作类型?) then (公积金管理)
  :查看公积金列表;
  if (子操作?) then (基数调整)
    :点击【基数调整】按钮;
    :选择调整员工;
    :输入新基数;
    :选择生效日期;
    :调整成功\n刷新列表;
  elseif (子操作?) then (汇缴记录)
    :点击【汇缴记录】按钮;
    :查看汇缴明细;
    :查看缴纳状态;
    :查看缴纳凭证;
  else (导出报表)
    :点击【导出】按钮;
    :选择导出月份;
    :下载公积金报表;
  endif
elseif (操作类型?) then (社保账单)
  :查看社保账单列表;
  if (子操作?) then (生成账单)
    :点击【生成账单】按钮;
    :选择账单月份;
    :系统计算费用;
    :账单生成成功\n刷新列表;
  elseif (子操作?) then (查看账单详情)
    :点击【查看详情】按钮;
    :查看账单明细;
    :查看个人缴纳;
    :查看单位缴纳;
  else (费用分析)
    :点击【费用分析】按钮;
    :查看费用趋势;
    :查看部门费用对比;
    :查看费用构成;
  endif
else (申报导出)
  :查看申报导出列表;
  if (子操作?) then (生成申报表)
    :点击【生成申报表】按钮;
    :选择申报月份;
    :选择申报类型;
    :申报表生成成功\n刷新列表;
  elseif (子操作?) then (导出申报数据)
    :点击【导出数据】按钮;
    :选择导出格式;
    :下载申报数据文件;
  else (打印申报表)
    :点击【打印】按钮;
    :预览申报表;
    :确认打印;
    :打印完成;
  endif
endif

stop

@enduml
