@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "绩效管理页面"
participant "后端服务"
database "数据库"

== 查看绩效列表流程 ==

用户 -> "绩效管理页面": 进入绩效管理页面
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 请求绩效列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询绩效数据
activate "数据库"
"数据库" --> "后端服务": 返回绩效列表
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回列表数据
deactivate "后端服务"
"绩效管理页面" --> 用户: 展示绩效列表
deactivate "绩效管理页面"

== 设定目标流程 ==

用户 -> "绩效管理页面": 点击【设定目标】，填写目标信息
用户 -> "绩效管理页面": 点击【保存】
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 提交目标设定请求\n(携带目标数据)
activate "后端服务"
"后端服务" -> "数据库": 插入目标记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回成功响应
deactivate "后端服务"
"绩效管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "绩效管理页面"

== 更新进度流程 ==

用户 -> "绩效管理页面": 点击【更新进度】按钮
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 请求目标详情
activate "后端服务"
"后端服务" -> "数据库": 查询目标详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回详情数据
deactivate "后端服务"
"绩效管理页面" --> 用户: 打开进度更新弹窗\n回显数据
deactivate "绩效管理页面"

用户 -> "绩效管理页面": 填写进度信息，点击【保存】
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 提交进度更新请求
activate "后端服务"
"后端服务" -> "数据库": 更新进度记录
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回成功响应
deactivate "后端服务"
"绩效管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "绩效管理页面"

== 绩效评估流程 ==

用户 -> "绩效管理页面": 点击【评估】按钮
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 请求评估表单
activate "后端服务"
"后端服务" -> "数据库": 查询评估配置
activate "数据库"
"数据库" --> "后端服务": 返回评估表单配置
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回表单数据
deactivate "后端服务"
"绩效管理页面" --> 用户: 打开评估弹窗\n显示评估表单
deactivate "绩效管理页面"

用户 -> "绩效管理页面": 填写评估内容，点击【提交】
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 提交评估请求
activate "后端服务"
"后端服务" -> "数据库": 插入评估记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回成功响应
deactivate "后端服务"
"绩效管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "绩效管理页面"

== 绩效校准流程 ==

用户 -> "绩效管理页面": 点击【校准】按钮
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 请求校准数据
activate "后端服务"
"后端服务" -> "数据库": 查询评估结果和分布配置
activate "数据库"
"数据库" --> "后端服务": 返回校准数据
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回校准数据
deactivate "后端服务"
"绩效管理页面" --> 用户: 打开校准弹窗\n显示强制分布
deactivate "绩效管理页面"

用户 -> "绩效管理页面": 调整评定结果，点击【保存】
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 提交校准请求
activate "后端服务"
"后端服务" -> "数据库": 更新评定结果
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回成功响应
deactivate "后端服务"
"绩效管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "绩效管理页面"

== 查看档案流程 ==

用户 -> "绩效管理页面": 点击【查看档案】按钮
activate "绩效管理页面"
"绩效管理页面" -> "后端服务": 请求绩效档案
activate "后端服务"
"后端服务" -> "数据库": 查询历史绩效记录
activate "数据库"
"数据库" --> "后端服务": 返回档案数据
deactivate "数据库"
"后端服务" --> "绩效管理页面": 返回档案数据
deactivate "后端服务"
"绩效管理页面" --> 用户: 显示绩效档案\n展示趋势图
deactivate "绩效管理页面"

@enduml
