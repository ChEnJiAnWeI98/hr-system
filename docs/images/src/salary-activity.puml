@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入薪酬管理页面;
:查看薪酬功能模块;

:选择操作;

if (操作类型?) then (薪资结构配置)
  :查看薪资结构列表;
  if (子操作?) then (新增薪资结构)
    :点击【新增结构】按钮;
    :填写结构名称;
    :设置薪酬项目;
    :设置计算公式;
    :点击【保存】;
    if (数据验证?) then (验证通过)
      :保存成功\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (编辑薪资结构)
    :点击【编辑】按钮;
    :修改结构信息;
    :保存成功\n刷新列表;
  else (删除薪资结构)
    :点击【删除】按钮;
    :二次确认弹窗;
    if (确认?) then (确认)
      :删除成功\n刷新列表;
    else (取消)
      stop
    endif
  endif
elseif (操作类型?) then (薪酬计算)
  :查看薪酬计算列表;
  if (子操作?) then (生成工资)
    :点击【生成工资】按钮;
    :选择计算月份;
    :选择员工范围;
    :点击【开始计算】;
    :系统自动计算工资;
    :计算完成\n显示结果;
  elseif (子操作?) then (调整工资)
    :点击【调整】按钮;
    :修改工资项目;
    :填写调整原因;
    :点击【保存】;
    :调整成功\n刷新列表;
  else (查看计算详情)
    :点击【查看详情】按钮;
    :查看工资明细;
    :查看计算过程;
    :查看扣款项目;
  endif
elseif (操作类型?) then (工资条管理)
  :查看工资条列表;
  if (子操作?) then (发放工资条)
    :点击【发放工资条】按钮;
    :选择发放月份;
    :选择发放方式;
    :点击【确认发放】;
    :发放成功\n刷新列表;
  elseif (子操作?) then (查看工资条)
    :点击【查看】按钮;
    :查看工资条详情;
    :查看应发金额;
    :查看实发金额;
  else (导出工资条)
    :点击【导出】按钮;
    :选择导出格式;
    :下载工资条文件;
  endif
elseif (操作类型?) then (个税申报)
  :查看个税申报列表;
  if (子操作?) then (生成个税申报)
    :点击【生成申报】按钮;
    :选择申报月份;
    :系统计算个税;
    :申报表生成成功;
  elseif (子操作?) then (专项附加扣除)
    :点击【专项扣除】按钮;
    :选择员工;
    :填写扣除信息;
    :点击【保存】;
    :保存成功\n刷新列表;
  else (导出申报表)
    :点击【导出申报表】按钮;
    :选择导出格式;
    :下载申报表文件;
  endif
else (调薪管理)
  :查看调薪申请列表;
  if (子操作?) then (提交调薪申请)
    :点击【调薪申请】按钮;
    :选择员工;
    :填写调薪信息;
    :填写调薪原因;
    :点击【提交】;
    if (数据验证?) then (验证通过)
      :提交成功\n发起审批流程\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (审批调薪申请)
    :点击【审批】按钮;
    :查看调薪详情;
    :填写审批意见;
    :点击【通过】或【拒绝】;
    :审批完成\n刷新列表;
  else (查看调薪历史)
    :点击【查看历史】按钮;
    :查看调薪记录;
    :查看调薪前后对比;
    :查看审批流程;
  endif
endif

stop

@enduml
