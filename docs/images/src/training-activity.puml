@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入培训管理页面;
:查看培训功能模块;

:选择操作;

if (操作类型?) then (培训计划管理)
  :查看培训计划列表;
  if (子操作?) then (新增计划)
    :点击【新增计划】按钮;
    :填写计划信息;
    :选择培训对象;
    :设置培训时间;
    :点击【保存】;
    if (数据验证?) then (验证通过)
      :保存成功\n刷新列表;
    else (验证失败)
      :显示错误提示\n停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (编辑计划)
    :点击【编辑】按钮;
    :修改计划信息;
    :保存成功\n刷新列表;
  else (删除计划)
    :点击【删除】按钮;
    :二次确认弹窗;
    if (确认?) then (确认)
      :删除成功\n刷新列表;
    else (取消)
      stop
    endif
  endif
elseif (操作类型?) then (课程管理)
  :查看课程列表;
  if (子操作?) then (新增课程)
    :点击【新增课程】按钮;
    :填写课程信息;
    :设置课程类型;
    :上传课程资料;
    :课程保存成功\n刷新列表;
  elseif (子操作?) then (编辑课程)
    :点击【编辑】按钮;
    :修改课程信息;
    :课程更新成功\n刷新列表;
  elseif (子操作?) then (删除课程)
    :点击【删除】按钮;
    :二次确认弹窗;
    if (确认删除?) then (确认)
      :课程删除成功\n刷新列表;
    else (取消)
      stop
    endif
  else (上传课件)
    :点击【上传课件】按钮;
    :选择文件;
    if (文件验证?) then (验证通过)
      :上传成功\n刷新列表;
    else (验证失败)
      :显示错误提示\n重新选择;
      detach
    endif
  endif
elseif (操作类型?) then (培训记录管理)
  :查看培训记录列表;
  if (子操作?) then (记录签到)
    :点击【签到】按钮;
    :扫描二维码或手动签到;
    :签到成功\n刷新列表;
  elseif (子操作?) then (查看详情)
    :点击【查看详情】按钮;
    :查看培训详细信息;
    :查看参训人员列表;
    :查看签到情况;
  else (导出记录)
    :点击【导出】按钮;
    :选择导出格式;
    :下载培训记录文件;
  endif
else (培训评估)
  :查看评估列表;
  if (子操作?) then (发起评估)
    :点击【发起评估】按钮;
    :选择培训项目;
    :设置评估问卷;
    :选择评估对象;
    :发起评估成功;
  elseif (子操作?) then (填写评估)
    :点击【填写评估】按钮;
    :填写评估问卷;
    :提交评估;
    :评估提交成功;
  else (查看评估结果)
    :点击【查看结果】按钮;
    :查看评估统计;
    :查看评估详情;
    :导出评估报告;
  endif
endif

stop

@enduml
