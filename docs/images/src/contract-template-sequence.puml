@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "合同模板管理页面"
participant "后端服务"
database "数据库"

== 查看列表流程 ==

用户 -> "合同模板管理页面": 进入合同模板管理页面
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 请求模板列表\n(携带筛选参数)
activate "后端服务"
"后端服务" -> "数据库": 查询模板数据
activate "数据库"
"数据库" --> "后端服务": 返回模板列表
deactivate "数据库"
"后端服务" --> "合同模板管理页面": 返回列表数据
deactivate "后端服务"
"合同模板管理页面" --> 用户: 展示模板列表
deactivate "合同模板管理页面"

== 新增流程 ==

用户 -> "合同模板管理页面": 点击【新增模板】
activate "合同模板管理页面"
"合同模板管理页面" --> 用户: 打开新增页面
deactivate "合同模板管理页面"

用户 -> "合同模板管理页面": 填写表单，编辑内容，插入变量
用户 -> "合同模板管理页面": 点击【保存】
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 提交新增请求\n(携带模板数据)
activate "后端服务"
"后端服务" -> "数据库": 检查模板名称是否重复
activate "数据库"
"数据库" --> "后端服务": 返回检查结果
deactivate "数据库"

alt 名称不重复
  "后端服务" -> "数据库": 插入模板记录\n(版本号=1)
  activate "数据库"
  "数据库" --> "后端服务": 返回插入结果
  deactivate "数据库"
  "后端服务" --> "合同模板管理页面": 返回成功响应
  deactivate "后端服务"
  "合同模板管理页面" --> 用户: 显示成功提示\n刷新列表
  deactivate "合同模板管理页面"
else 名称重复
  "后端服务" --> "合同模板管理页面": 返回错误响应
  deactivate "后端服务"
  "合同模板管理页面" --> 用户: 显示错误提示
  deactivate "合同模板管理页面"
end

== 编辑流程 ==

用户 -> "合同模板管理页面": 点击【编辑】按钮
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 请求模板详情
activate "后端服务"
"后端服务" -> "数据库": 查询模板详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "合同模板管理页面": 返回详情数据
deactivate "后端服务"
"合同模板管理页面" --> 用户: 打开编辑页面\n回显数据
deactivate "合同模板管理页面"

用户 -> "合同模板管理页面": 修改数据，点击【保存】
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 提交更新请求
activate "后端服务"
"后端服务" -> "数据库": 保存历史版本\n(版本号+1)
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" -> "数据库": 更新当前版本记录
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同模板管理页面": 返回成功响应
deactivate "后端服务"
"合同模板管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同模板管理页面"

== 版本管理流程 ==

用户 -> "合同模板管理页面": 点击【版本历史】按钮
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 请求版本历史列表
activate "后端服务"
"后端服务" -> "数据库": 查询历史版本
activate "数据库"
"数据库" --> "后端服务": 返回版本列表
deactivate "数据库"
"后端服务" --> "合同模板管理页面": 返回版本数据
deactivate "后端服务"
"合同模板管理页面" --> 用户: 展示版本历史列表
deactivate "合同模板管理页面"

用户 -> "合同模板管理页面": 选择版本，点击【恢复】
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 提交恢复请求\n(携带版本ID)
activate "后端服务"
"后端服务" -> "数据库": 查询指定版本数据
activate "数据库"
"数据库" --> "后端服务": 返回版本数据
deactivate "数据库"
"后端服务" -> "数据库": 保存当前版本为历史\n(版本号+1)
activate "数据库"
"数据库" --> "后端服务": 返回保存结果
deactivate "数据库"
"后端服务" -> "数据库": 更新当前版本为选定版本
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同模板管理页面": 返回成功响应
deactivate "后端服务"
"合同模板管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同模板管理页面"

== 启用/停用流程 ==

用户 -> "合同模板管理页面": 点击【启用】或【停用】
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 提交状态更新请求
activate "后端服务"
"后端服务" -> "数据库": 更新模板状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同模板管理页面": 返回成功响应
deactivate "后端服务"
"合同模板管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同模板管理页面"

== 设为默认流程 ==

用户 -> "合同模板管理页面": 点击【设为默认】
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 提交设置默认请求
activate "后端服务"
"后端服务" -> "数据库": 取消其他模板的默认标识
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 设置当前模板为默认
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同模板管理页面": 返回成功响应
deactivate "后端服务"
"合同模板管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同模板管理页面"

== 删除流程 ==

用户 -> "合同模板管理页面": 点击【删除】按钮
activate "合同模板管理页面"
"合同模板管理页面" -> "后端服务": 检查模板是否被使用
activate "后端服务"
"后端服务" -> "数据库": 查询关联的合同记录
activate "数据库"
"数据库" --> "后端服务": 返回关联记录数
deactivate "数据库"

alt 模板未被使用
  "后端服务" --> "合同模板管理页面": 返回可删除标识
  deactivate "后端服务"
  "合同模板管理页面" --> 用户: 显示二次确认弹窗
  deactivate "合同模板管理页面"

  用户 -> "合同模板管理页面": 确认删除
  activate "合同模板管理页面"
  "合同模板管理页面" -> "后端服务": 提交删除请求
  activate "后端服务"
  "后端服务" -> "数据库": 软删除模板记录
  activate "数据库"
  "数据库" --> "后端服务": 返回删除结果
  deactivate "数据库"
  "后端服务" --> "合同模板管理页面": 返回成功响应
  deactivate "后端服务"
  "合同模板管理页面" --> 用户: 显示成功提示\n刷新列表
  deactivate "合同模板管理页面"
else 模板已被使用
  "后端服务" --> "合同模板管理页面": 返回不可删除标识
  deactivate "后端服务"
  "合同模板管理页面" --> 用户: 提示"模板已被使用，无法删除"
  deactivate "合同模板管理页面"
end

@enduml
