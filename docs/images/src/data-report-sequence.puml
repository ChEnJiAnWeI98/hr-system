@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "数据报表页面"
participant "后端服务"
database "数据库"

== 查看HR驾驶舱流程 ==

用户 -> "数据报表页面": 进入数据报表与分析页面
activate "数据报表页面"
"数据报表页面" -> "后端服务": 请求HR驾驶舱数据
activate "后端服务"
"后端服务" -> "数据库": 查询实时统计数据
activate "数据库"
"数据库" --> "后端服务": 返回统计数据
deactivate "数据库"
"后端服务" --> "数据报表页面": 返回驾驶舱数据
deactivate "后端服务"
"数据报表页面" --> 用户: 展示统计卡片和趋势图表
deactivate "数据报表页面"

== 人员分析报表流程 ==

用户 -> "数据报表页面": 点击【人员分析报表】
activate "数据报表页面"
用户 -> "数据报表页面": 设置筛选条件，选择分析维度
"数据报表页面" -> "后端服务": 请求人员分析数据\n(携带筛选条件)
activate "后端服务"
"后端服务" -> "数据库": 查询人员数据
activate "数据库"
"数据库" --> "后端服务": 返回人员数据
deactivate "数据库"
"后端服务" --> "数据报表页面": 返回分析结果
deactivate "后端服务"
"数据报表页面" --> 用户: 展示分析图表
deactivate "数据报表页面"

== 薪酬分析报表流程 ==

用户 -> "数据报表页面": 点击【薪酬分析报表】
activate "数据报表页面"
用户 -> "数据报表页面": 设置时间范围和部门范围
"数据报表页面" -> "后端服务": 请求薪酬分析数据\n(携带时间和部门参数)
activate "后端服务"
"后端服务" -> "数据库": 查询薪酬数据
activate "数据库"
"数据库" --> "后端服务": 返回薪酬数据
deactivate "数据库"
"后端服务" --> "数据报表页面": 返回薪酬分布和成本趋势
deactivate "后端服务"
"数据报表页面" --> 用户: 展示薪酬分析图表
deactivate "数据报表页面"

== 招聘漏斗报表流程 ==

用户 -> "数据报表页面": 点击【招聘漏斗报表】
activate "数据报表页面"
用户 -> "数据报表页面": 设置统计周期
"数据报表页面" -> "后端服务": 请求招聘漏斗数据\n(携带周期参数)
activate "后端服务"
"后端服务" -> "数据库": 查询招聘数据
activate "数据库"
"数据库" --> "后端服务": 返回招聘各阶段数据
deactivate "数据库"
"后端服务" --> "数据报表页面": 返回漏斗数据和转化率
deactivate "后端服务"
"数据报表页面" --> 用户: 展示招聘漏斗图和转化率
deactivate "数据报表页面"

== 考勤报表流程 ==

用户 -> "数据报表页面": 点击【考勤报表】
activate "数据报表页面"
用户 -> "数据报表页面": 设置查询月份和部门
"数据报表页面" -> "后端服务": 请求考勤报表数据\n(携带月份和部门参数)
activate "后端服务"
"后端服务" -> "数据库": 查询考勤数据
activate "数据库"
"数据库" --> "后端服务": 返回考勤统计和异常明细
deactivate "数据库"
"后端服务" --> "数据报表页面": 返回考勤报表数据
deactivate "后端服务"
"数据报表页面" --> 用户: 展示考勤统计和异常明细
deactivate "数据报表页面"

== 导出报表流程 ==

用户 -> "数据报表页面": 点击【导出报表】
activate "数据报表页面"
用户 -> "数据报表页面": 选择导出格式(Excel/PDF)
"数据报表页面" -> "后端服务": 请求导出报表\n(携带报表类型和格式)
activate "后端服务"
"后端服务" -> "数据库": 查询完整报表数据
activate "数据库"
"数据库" --> "后端服务": 返回完整数据
deactivate "数据库"
"后端服务" --> "数据报表页面": 返回导出文件
deactivate "后端服务"
"数据报表页面" --> 用户: 下载报表文件
deactivate "数据报表页面"

@enduml
