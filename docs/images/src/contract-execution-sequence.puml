@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "合同管理页面"
participant "后端服务"
database "数据库"

== 查看合同列表流程 ==

用户 -> "合同管理页面": 进入合同管理页面
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询合同列表
activate "数据库"
"数据库" --> "后端服务": 返回合同列表
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回列表数据
deactivate "后端服务"
"合同管理页面" --> 用户: 展示合同列表\n生效中的合同显示【续签】【变更】【终止】按钮
deactivate "合同管理页面"

== 合同续签流程 ==

用户 -> "合同管理页面": 点击【续签】按钮
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求原合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询原合同信息
activate "数据库"
"数据库" --> "后端服务": 返回原合同信息
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回原合同数据
deactivate "后端服务"
"合同管理页面" --> 用户: 打开续签弹窗\n回显原合同部分信息
deactivate "合同管理页面"

用户 -> "合同管理页面": 填写新合同期限、薪资标准\n点击【提交审批】
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交续签请求\n(携带续签数据)
activate "后端服务"
"后端服务" -> "后端服务": 验证数据完整性
alt 验证失败
    "后端服务" --> "合同管理页面": 返回验证错误信息
    "合同管理页面" --> 用户: 显示错误提示
else 验证通过
    "后端服务" -> "数据库": 创建续签记录
    activate "数据库"
    "数据库" --> "后端服务": 返回创建结果
    deactivate "数据库"
    "后端服务" -> "数据库": 创建审批流程实例
    activate "数据库"
    "数据库" --> "后端服务": 返回流程实例ID
    deactivate "数据库"
    "后端服务" -> "后端服务": 发送审批通知
    "后端服务" --> "合同管理页面": 返回提交成功响应
    deactivate "后端服务"
    "合同管理页面" --> 用户: 显示提交成功提示\n进入审批流程
    deactivate "合同管理页面"
end

== 审批通过后续签生效 ==

用户 -> "合同管理页面": 审批通过后查看合同
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同列表
activate "后端服务"
"后端服务" -> "数据库": 查询审批通过的续签记录
activate "数据库"
"数据库" --> "后端服务": 返回续签记录
deactivate "数据库"
"后端服务" -> "数据库": 生成新合同记录
activate "数据库"
"数据库" --> "后端服务": 返回新合同ID
deactivate "数据库"
"后端服务" -> "数据库": 更新原合同状态为"已续签"
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回合同列表
deactivate "后端服务"
"合同管理页面" --> 用户: 显示续签成功\n原合同状态为"已续签"\n新合同状态为"生效中"
deactivate "合同管理页面"

== 合同变更流程 ==

用户 -> "合同管理页面": 点击【变更】按钮
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询合同信息
activate "数据库"
"数据库" --> "后端服务": 返回合同信息
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回合同数据
deactivate "后端服务"
"合同管理页面" --> 用户: 打开变更弹窗\n回显当前合同信息
deactivate "合同管理页面"

用户 -> "合同管理页面": 选择变更类型\n填写变更内容和原因\n点击【提交审批】
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交变更请求\n(携带变更数据)
activate "后端服务"
"后端服务" -> "后端服务": 验证数据完整性
alt 验证失败
    "后端服务" --> "合同管理页面": 返回验证错误信息
    "合同管理页面" --> 用户: 显示错误提示
else 验证通过
    "后端服务" -> "数据库": 创建变更记录
    activate "数据库"
    "数据库" --> "后端服务": 返回创建结果
    deactivate "数据库"
    "后端服务" -> "数据库": 创建审批流程实例
    activate "数据库"
    "数据库" --> "后端服务": 返回流程实例ID
    deactivate "数据库"
    "后端服务" -> "后端服务": 发送审批通知
    "后端服务" --> "合同管理页面": 返回提交成功响应
    deactivate "后端服务"
    "合同管理页面" --> 用户: 显示提交成功提示\n进入审批流程
    deactivate "合同管理页面"
end

== 审批通过后变更生效 ==

用户 -> "合同管理页面": 审批通过后查看合同
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询审批通过的变更记录
activate "数据库"
"数据库" --> "后端服务": 返回变更记录
deactivate "数据库"
"后端服务" -> "数据库": 更新合同信息
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 记录变更历史
activate "数据库"
"数据库" --> "后端服务": 返回记录结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回合同详情
deactivate "后端服务"
"合同管理页面" --> 用户: 显示变更成功\n合同信息已更新
deactivate "合同管理页面"

== 合同终止流程 ==

用户 -> "合同管理页面": 点击【终止】按钮
activate "合同管理页面"
"合同管理页面" --> 用户: 打开终止确认弹窗
deactivate "合同管理页面"

用户 -> "合同管理页面": 填写终止原因、终止日期、终止类型\n点击【提交审批】
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交终止请求\n(携带终止数据)
activate "后端服务"
"后端服务" -> "后端服务": 验证数据完整性
alt 验证失败
    "后端服务" --> "合同管理页面": 返回验证错误信息
    "合同管理页面" --> 用户: 显示错误提示
else 验证通过
    "后端服务" -> "数据库": 创建终止记录
    activate "数据库"
    "数据库" --> "后端服务": 返回创建结果
    deactivate "数据库"
    "后端服务" -> "数据库": 创建审批流程实例
    activate "数据库"
    "数据库" --> "后端服务": 返回流程实例ID
    deactivate "数据库"
    "后端服务" -> "后端服务": 发送审批通知
    "后端服务" --> "合同管理页面": 返回提交成功响应
    deactivate "后端服务"
    "合同管理页面" --> 用户: 显示提交成功提示\n进入审批流程
    deactivate "合同管理页面"
end

== 审批通过后终止生效 ==

用户 -> "合同管理页面": 审批通过后查看合同
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询审批通过的终止记录
activate "数据库"
"数据库" --> "后端服务": 返回终止记录
deactivate "数据库"
"后端服务" -> "数据库": 更新合同状态为"已终止"
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 记录终止信息
activate "数据库"
"数据库" --> "后端服务": 返回记录结果
deactivate "数据库"
"后端服务" -> "数据库": 关联离职流程
activate "数据库"
"数据库" --> "后端服务": 返回关联结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回合同详情
deactivate "后端服务"
"合同管理页面" --> 用户: 显示终止成功\n合同状态为"已终止"
deactivate "合同管理页面"

== 查看操作历史流程 ==

用户 -> "合同管理页面": 点击【查看详情】按钮
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同完整信息
activate "后端服务"
"后端服务" -> "数据库": 查询合同详情
activate "数据库"
"数据库" --> "后端服务": 返回合同数据
deactivate "数据库"
"后端服务" -> "数据库": 查询续签记录
activate "数据库"
"数据库" --> "后端服务": 返回续签记录
deactivate "数据库"
"后端服务" -> "数据库": 查询变更历史
activate "数据库"
"数据库" --> "后端服务": 返回变更历史
deactivate "数据库"
"后端服务" -> "数据库": 查询终止记录
activate "数据库"
"数据库" --> "后端服务": 返回终止记录
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回完整数据
deactivate "后端服务"
"合同管理页面" --> 用户: 打开详情页面\n显示合同完整信息\n包括续签记录、变更历史、终止记录
deactivate "合同管理页面"

@enduml
