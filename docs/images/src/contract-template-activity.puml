@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start

:进入合同模板管理页面;
:查看模板列表\n(默认展示全部模板);

:选择操作;

if (操作类型?) then (新增模板)
  :点击【新增模板】按钮;
  :填写模板基本信息\n(模板名称、模板类型、模板分类);
  :在富文本编辑器中编辑模板内容;
  :插入变量占位符\n(员工姓名、工号、部门等);
  :预览模板效果;
  :点击【保存】;

  if (数据验证) then (验证通过)
    :保存成功\n刷新列表;
  else (验证失败)
    :显示错误提示\n(模板名称重复/内容为空);
    :停留在编辑页面;
    stop
  endif

elseif (操作类型?) then (编辑模板)
  :点击【编辑】按钮;
  :系统打开编辑页面\n回显模板信息;
  :修改模板信息;
  :点击【保存】;

  if (数据验证) then (验证通过)
    :保存成功\n刷新列表;
  else (验证失败)
    :显示错误提示;
    :停留在编辑页面;
    stop
  endif

elseif (操作类型?) then (版本管理)
  :点击【版本历史】按钮;
  :查看历史版本列表;

  if (选择操作) then (预览版本)
    :查看历史版本内容;
    stop
  else (恢复版本)
    :选择要恢复的版本;
    :二次确认;
    if (确认?) then (确认)
      :恢复到选定版本\n刷新列表;
    else (取消)
      stop
    endif
  endif

elseif (操作类型?) then (启用/停用)
  :点击【启用】或【停用】按钮;
  :系统更新模板状态;
  :显示成功提示\n刷新列表;

elseif (操作类型?) then (设为默认)
  :点击【设为默认】按钮;
  :系统将该模板设为默认模板;
  :显示成功提示\n刷新列表;

elseif (操作类型?) then (删除模板)
  :点击【删除】按钮;

  if (模板是否被使用?) then (已被使用)
    :提示"模板已被使用，无法删除";
    stop
  else (未被使用)
    :二次确认弹窗;
    if (确认删除?) then (确认)
      :删除成功\n刷新列表;
    else (取消)
      stop
    endif
  endif

endif

stop

@enduml
