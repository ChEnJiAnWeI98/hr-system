@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "员工自助页面"
participant "后端服务"
database "数据库"

== 查看个人信息流程 ==

用户 -> "员工自助页面": 进入个人信息页面
activate "员工自助页面"
"员工自助页面" -> "后端服务": 请求个人信息
activate "后端服务"
"后端服务" -> "数据库": 查询员工信息
activate "数据库"
"数据库" --> "后端服务": 返回员工信息
deactivate "数据库"
"后端服务" --> "员工自助页面": 返回个人信息
deactivate "后端服务"
"员工自助页面" --> 用户: 展示个人信息
deactivate "员工自助页面"

== 修改个人信息流程 ==

用户 -> "员工自助页面": 点击【编辑】，修改信息
用户 -> "员工自助页面": 点击【保存】
activate "员工自助页面"
"员工自助页面" -> "后端服务": 提交修改请求\n(携带修改数据)
activate "后端服务"
"后端服务" -> "数据库": 更新员工信息
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "员工自助页面": 返回成功响应
deactivate "后端服务"
"员工自助页面" --> 用户: 显示成功提示\n刷新页面
deactivate "员工自助页面"

== 查看工资条流程 ==

用户 -> "员工自助页面": 进入工资条查询页面
activate "员工自助页面"
"员工自助页面" -> "后端服务": 请求工资条列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询工资条数据
activate "数据库"
"数据库" --> "后端服务": 返回工资条列表
deactivate "数据库"
"后端服务" --> "员工自助页面": 返回列表数据
deactivate "后端服务"
"员工自助页面" --> 用户: 展示工资条列表
deactivate "员工自助页面"

== 查看工资详情流程 ==

用户 -> "员工自助页面": 点击【查看详情】按钮
activate "员工自助页面"
"员工自助页面" -> "后端服务": 请求工资详情
activate "后端服务"
"后端服务" -> "数据库": 查询工资明细
activate "数据库"
"数据库" --> "后端服务": 返回工资明细
deactivate "数据库"
"后端服务" --> "员工自助页面": 返回详情数据
deactivate "后端服务"
"员工自助页面" --> 用户: 展示工资详情
deactivate "员工自助页面"

== 查看假期余额流程 ==

用户 -> "员工自助页面": 进入假期余额查询页面
activate "员工自助页面"
"员工自助页面" -> "后端服务": 请求假期余额
activate "后端服务"
"后端服务" -> "数据库": 查询假期余额数据
activate "数据库"
"数据库" --> "后端服务": 返回假期余额
deactivate "数据库"
"后端服务" --> "员工自助页面": 返回余额数据
deactivate "后端服务"
"员工自助页面" --> 用户: 展示假期余额
deactivate "员工自助页面"

== 提交请假申请流程 ==

用户 -> "员工自助页面": 点击【申请请假】，填写信息
用户 -> "员工自助页面": 上传附件，点击【提交】
activate "员工自助页面"
"员工自助页面" -> "后端服务": 提交请假申请\n(携带申请数据和附件)
activate "后端服务"
"后端服务" -> "数据库": 插入请假申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请ID
deactivate "数据库"
"后端服务" -> "后端服务": 检查假期余额是否充足
"后端服务" -> "后端服务": 创建审批流程实例\n确定审批人
"后端服务" -> "后端服务": 发送审批通知
"后端服务" --> "员工自助页面": 返回成功响应
deactivate "后端服务"
"员工自助页面" --> 用户: 显示提交成功\n刷新列表
deactivate "员工自助页面"

== 提交其他申请流程 ==

用户 -> "员工自助页面": 点击【新建申请】，选择类型
用户 -> "员工自助页面": 填写申请表单，点击【提交】
activate "员工自助页面"
"员工自助页面" -> "后端服务": 提交申请\n(携带申请数据)
activate "后端服务"
"后端服务" -> "数据库": 插入申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请ID
deactivate "数据库"
"后端服务" -> "后端服务": 创建审批流程实例
"后端服务" -> "后端服务": 发送审批通知
"后端服务" --> "员工自助页面": 返回成功响应
deactivate "后端服务"
"员工自助页面" --> 用户: 显示提交成功\n刷新列表
deactivate "员工自助页面"

== 撤回申请流程 ==

用户 -> "员工自助页面": 点击【撤回】，确认弹窗
activate "员工自助页面"
"员工自助页面" -> "后端服务": 提交撤回请求
activate "后端服务"
"后端服务" -> "数据库": 更新申请状态为已撤回
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "后端服务": 终止审批流程
"后端服务" -> "后端服务": 发送撤回通知
"后端服务" --> "员工自助页面": 返回成功响应
deactivate "后端服务"
"员工自助页面" --> 用户: 显示撤回成功\n刷新列表
deactivate "员工自助页面"

== 查看待办任务流程 ==

用户 -> "员工自助页面": 进入待办任务页面
activate "员工自助页面"
"员工自助页面" -> "后端服务": 请求待办任务列表
activate "后端服务"
"后端服务" -> "数据库": 查询待办任务
activate "数据库"
"数据库" --> "后端服务": 返回待办任务列表
deactivate "数据库"
"后端服务" --> "员工自助页面": 返回列表数据
deactivate "后端服务"
"员工自助页面" --> 用户: 展示待办任务列表
deactivate "员工自助页面"

@enduml
