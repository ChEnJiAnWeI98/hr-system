@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "考勤管理页面"
participant "后端服务"
database "数据库"

== 查看考勤规则列表流程 ==

用户 -> "考勤管理页面": 进入考勤规则管理
activate "考勤管理页面"
"考勤管理页面" -> "后端服务": 请求考勤规则列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询考勤规则数据
activate "数据库"
"数据库" --> "后端服务": 返回考勤规则列表
deactivate "数据库"
"后端服务" --> "考勤管理页面": 返回列表数据
deactivate "后端服务"
"考勤管理页面" --> 用户: 展示考勤规则列表
deactivate "考勤管理页面"

== 新增考勤规则流程 ==

用户 -> "考勤管理页面": 点击【新增规则】，填写信息
用户 -> "考勤管理页面": 点击【保存】
activate "考勤管理页面"
"考勤管理页面" -> "后端服务": 提交新增请求\n(携带规则数据)
activate "后端服务"
"后端服务" -> "数据库": 插入考勤规则记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "考勤管理页面": 返回成功响应
deactivate "后端服务"
"考勤管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "考勤管理页面"

== 员工打卡流程 ==

用户 -> "考勤管理页面": 点击【打卡】按钮
activate "考勤管理页面"
"考勤管理页面" -> "考勤管理页面": 获取当前位置信息
"考勤管理页面" -> "考勤管理页面": 拍摄打卡照片
用户 -> "考勤管理页面": 点击【确认打卡】
"考勤管理页面" -> "后端服务": 提交打卡请求\n(携带时间、位置、照片)
activate "后端服务"
"后端服务" -> "数据库": 查询员工考勤规则
activate "数据库"
"数据库" --> "后端服务": 返回考勤规则
deactivate "数据库"
"后端服务" -> "后端服务": 判断打卡类型\n(上班/下班)
"后端服务" -> "后端服务": 计算是否迟到/早退
"后端服务" -> "数据库": 插入打卡记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "考勤管理页面": 返回打卡结果
deactivate "后端服务"
"考勤管理页面" --> 用户: 显示打卡成功\n刷新列表
deactivate "考勤管理页面"

== 补卡申请流程 ==

用户 -> "考勤管理页面": 点击【补卡申请】，填写信息
用户 -> "考勤管理页面": 上传证明材料，点击【提交】
activate "考勤管理页面"
"考勤管理页面" -> "后端服务": 提交补卡申请\n(携带申请数据和附件)
activate "后端服务"
"后端服务" -> "数据库": 插入补卡申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请ID
deactivate "数据库"
"后端服务" -> "后端服务": 创建审批流程实例\n确定审批人
"后端服务" -> "后端服务": 发送审批通知
"后端服务" --> "考勤管理页面": 返回成功响应
deactivate "后端服务"
"考勤管理页面" --> 用户: 显示提交成功\n刷新列表
deactivate "考勤管理页面"

== 加班申请流程 ==

用户 -> "考勤管理页面": 点击【加班申请】，填写信息
用户 -> "考勤管理页面": 点击【提交】
activate "考勤管理页面"
"考勤管理页面" -> "后端服务": 提交加班申请\n(携带申请数据)
activate "后端服务"
"后端服务" -> "数据库": 插入加班申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请ID
deactivate "数据库"
"后端服务" -> "后端服务": 创建审批流程实例\n确定审批人
"后端服务" -> "后端服务": 发送审批通知
"后端服务" --> "考勤管理页面": 返回成功响应
deactivate "后端服务"
"考勤管理页面" --> 用户: 显示提交成功\n刷新列表
deactivate "考勤管理页面"

== 审批通过后处理流程 ==

用户 -> "考勤管理页面": 审批人审批通过加班申请
activate "考勤管理页面"
"考勤管理页面" -> "后端服务": 提交审批结果
activate "后端服务"
"后端服务" -> "数据库": 更新申请状态为已通过
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "后端服务": 计算加班时长
"后端服务" -> "后端服务": 判断转换方式\n(加班费/调休)
"后端服务" -> "数据库": 更新员工加班时长\n或调休额度
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "后端服务": 发送审批结果通知
"后端服务" --> "考勤管理页面": 返回成功响应
deactivate "后端服务"
"考勤管理页面" --> 用户: 显示审批成功\n刷新列表
deactivate "考勤管理页面"

== 外勤打卡流程 ==

用户 -> "考勤管理页面": 点击【外勤打卡】按钮
activate "考勤管理页面"
"考勤管理页面" -> "考勤管理页面": 获取GPS定位信息
"考勤管理页面" -> "考勤管理页面": 拍摄现场照片
用户 -> "考勤管理页面": 点击【确认打卡】
"考勤管理页面" -> "后端服务": 提交外勤打卡\n(携带位置、照片、时间)
activate "后端服务"
"后端服务" -> "数据库": 查询外勤申请记录
activate "数据库"
"数据库" --> "后端服务": 返回外勤申请
deactivate "数据库"
"后端服务" -> "后端服务": 验证打卡位置\n是否在允许范围内
"后端服务" -> "数据库": 插入外勤打卡记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "考勤管理页面": 返回打卡结果
deactivate "后端服务"
"考勤管理页面" --> 用户: 显示打卡成功\n刷新列表
deactivate "考勤管理页面"

== 查看考勤统计流程 ==

用户 -> "考勤管理页面": 进入考勤统计页面
activate "考勤管理页面"
"考勤管理页面" -> "后端服务": 请求考勤统计数据\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询打卡记录
activate "数据库"
"数据库" --> "后端服务": 返回打卡记录
deactivate "数据库"
"后端服务" -> "数据库": 查询加班记录
activate "数据库"
"数据库" --> "后端服务": 返回加班记录
deactivate "数据库"
"后端服务" -> "数据库": 查询请假记录
activate "数据库"
"数据库" --> "后端服务": 返回请假记录
deactivate "数据库"
"后端服务" -> "后端服务": 统计出勤天数
"后端服务" -> "后端服务": 统计迟到早退次数
"后端服务" -> "后端服务": 统计加班时长
"后端服务" -> "后端服务": 统计异常记录
"后端服务" --> "考勤管理页面": 返回统计数据
deactivate "后端服务"
"考勤管理页面" --> 用户: 展示考勤统计报表
deactivate "考勤管理页面"

@enduml
