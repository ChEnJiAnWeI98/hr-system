@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "审批流引擎页面"
participant "后端服务"
database "数据库"

== 流程模板创建流程 ==

用户 -> "审批流引擎页面": 进入流程模板管理页面
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 请求流程模板列表
activate "后端服务"
"后端服务" -> "数据库": 查询流程模板
activate "数据库"
"数据库" --> "后端服务": 返回模板列表
deactivate "数据库"
"后端服务" --> "审批流引擎页面": 返回列表数据
deactivate "后端服务"
"审批流引擎页面" --> 用户: 展示流程模板列表
deactivate "审批流引擎页面"

用户 -> "审批流引擎页面": 点击【新增模板】，填写基本信息
用户 -> "审批流引擎页面": 在流程设计器中配置审批节点
用户 -> "审批流引擎页面": 设置审批人和条件分支规则
用户 -> "审批流引擎页面": 点击【保存】
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 提交模板配置数据\n(模板信息+节点配置+审批人规则)
activate "后端服务"
"后端服务" -> "后端服务": 验证流程配置\n(节点完整性、审批人有效性)
"后端服务" -> "数据库": 插入流程模板记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "审批流引擎页面": 返回成功响应
deactivate "后端服务"
"审批流引擎页面" --> 用户: 显示成功提示\n刷新列表
deactivate "审批流引擎页面"

== 审批实例发起流程 ==

用户 -> "审批流引擎页面": 进入审批实例管理页面
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 请求审批实例列表
activate "后端服务"
"后端服务" -> "数据库": 查询审批实例
activate "数据库"
"数据库" --> "后端服务": 返回实例列表
deactivate "数据库"
"后端服务" --> "审批流引擎页面": 返回列表数据
deactivate "后端服务"
"审批流引擎页面" --> 用户: 展示审批实例列表
deactivate "审批流引擎页面"

用户 -> "审批流引擎页面": 点击【发起审批】
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 请求可用的审批类型列表
activate "后端服务"
"后端服务" -> "数据库": 查询启用的流程模板
activate "数据库"
"数据库" --> "后端服务": 返回模板列表
deactivate "数据库"
"后端服务" --> "审批流引擎页面": 返回审批类型列表
deactivate "后端服务"
"审批流引擎页面" --> 用户: 展示审批类型选择
deactivate "审批流引擎页面"

用户 -> "审批流引擎页面": 选择审批类型，填写表单，上传附件
用户 -> "审批流引擎页面": 点击【提交】
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 提交审批申请\n(模板ID+表单数据+附件)
activate "后端服务"
"后端服务" -> "后端服务": 验证表单数据
"后端服务" -> "数据库": 查询流程模板配置
activate "数据库"
"数据库" --> "后端服务": 返回模板配置
deactivate "数据库"
"后端服务" -> "后端服务": 根据模板配置确定审批节点\n根据条件分支规则确定审批人
"后端服务" -> "数据库": 插入审批实例记录
activate "数据库"
"数据库" --> "后端服务": 返回实例ID
deactivate "数据库"
"后端服务" -> "数据库": 插入审批节点记录
activate "数据库"
"数据库" --> "后端服务": 返回节点记录
deactivate "数据库"
"后端服务" -> "后端服务": 发送审批通知给第一节点审批人
"后端服务" --> "审批流引擎页面": 返回成功响应
deactivate "后端服务"
"审批流引擎页面" --> 用户: 显示提交成功提示\n刷新列表
deactivate "审批流引擎页面"

== 审批处理流程 ==

用户 -> "审批流引擎页面": 进入待办审批页面
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 请求待处理审批列表\n(当前用户ID)
activate "后端服务"
"后端服务" -> "数据库": 查询待处理的审批节点\n(审批人=当前用户 且 状态=待处理)
activate "数据库"
"数据库" --> "后端服务": 返回待办列表
deactivate "数据库"
"后端服务" --> "审批流引擎页面": 返回列表数据
deactivate "后端服务"
"审批流引擎页面" --> 用户: 展示待办审批列表
deactivate "审批流引擎页面"

用户 -> "审批流引擎页面": 点击【审批】
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 请求审批详情\n(实例ID)
activate "后端服务"
"后端服务" -> "数据库": 查询审批实例详情
activate "数据库"
"数据库" --> "后端服务": 返回实例详情
deactivate "数据库"
"后端服务" -> "数据库": 查询审批历史记录
activate "数据库"
"数据库" --> "后端服务": 返回历史记录
deactivate "数据库"
"后端服务" --> "审批流引擎页面": 返回详情数据
deactivate "后端服务"
"审批流引擎页面" --> 用户: 展示审批详情\n(表单、附件、历史)
deactivate "审批流引擎页面"

用户 -> "审批流引擎页面": 填写审批意见，选择操作\n(通过/驳回/转签/加签)
用户 -> "审批流引擎页面": 点击【提交】
activate "审批流引擎页面"
"审批流引擎页面" -> "后端服务": 提交审批操作\n(节点ID+操作类型+审批意见)
activate "后端服务"
"后端服务" -> "数据库": 更新审批节点状态和审批意见
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"

alt 操作类型=通过
  "后端服务" -> "数据库": 查询是否为最后节点
  activate "数据库"
  "数据库" --> "后端服务": 返回节点信息
  deactivate "数据库"
  alt 是最后节点
    "后端服务" -> "数据库": 更新审批实例状态为"已完成"
    activate "数据库"
    "数据库" --> "后端服务": 返回更新结果
    deactivate "数据库"
    "后端服务" -> "后端服务": 更新业务状态\n发送完成通知
  else 不是最后节点
    "后端服务" -> "数据库": 查询下一节点审批人
    activate "数据库"
    "数据库" --> "后端服务": 返回下一节点信息
    deactivate "数据库"
    "后端服务" -> "后端服务": 发送审批通知给下一节点审批人
  end
else 操作类型=驳回
  "后端服务" -> "数据库": 更新审批实例状态为"已驳回"
  activate "数据库"
  "数据库" --> "后端服务": 返回更新结果
  deactivate "数据库"
  "后端服务" -> "后端服务": 发送驳回通知给发起人
else 操作类型=转签
  "后端服务" -> "数据库": 更新审批节点审批人为转签人
  activate "数据库"
  "数据库" --> "后端服务": 返回更新结果
  deactivate "数据库"
  "后端服务" -> "后端服务": 发送转签通知给转签人
else 操作类型=加签
  "后端服务" -> "数据库": 插入新的审批节点\n(前加签/后加签)
  activate "数据库"
  "数据库" --> "后端服务": 返回插入结果
  deactivate "数据库"
  "后端服务" -> "后端服务": 发送加签通知给加签人
end

"后端服务" --> "审批流引擎页面": 返回成功响应
deactivate "后端服务"
"审批流引擎页面" --> 用户: 显示成功提示\n刷新列表
deactivate "审批流引擎页面"

@enduml
