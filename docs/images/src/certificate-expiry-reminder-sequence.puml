@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "证件到期提醒页面"
participant "后端服务"
database "数据库"

== 查看证件列表流程 ==

用户 -> "证件到期提醒页面": 进入证件到期提醒页面
activate "证件到期提醒页面"
"证件到期提醒页面" -> "后端服务": 请求即将到期的证件列表\n(携带筛选条件：证件类型、到期时间范围、员工部门)
activate "后端服务"
"后端服务" -> "数据库": 查询即将到期的证件\n(按紧急程度排序)
activate "数据库"
"数据库" --> "后端服务": 返回证件列表
deactivate "数据库"
"后端服务" --> "证件到期提醒页面": 返回列表数据
deactivate "后端服务"
"证件到期提醒页面" --> 用户: 展示证件列表\n(按紧急程度排序)
deactivate "证件到期提醒页面"

== 查看证件详情流程 ==

用户 -> "证件到期提醒页面": 点击某个证件
activate "证件到期提醒页面"
"证件到期提醒页面" -> "后端服务": 请求证件详情
activate "后端服务"
"后端服务" -> "数据库": 查询证件详细信息
activate "数据库"
"数据库" --> "后端服务": 返回证件详情
deactivate "数据库"
"后端服务" --> "证件到期提醒页面": 返回详情数据
deactivate "后端服务"
"证件到期提醒页面" --> 用户: 显示证件详细信息
deactivate "证件到期提醒页面"

== 通知员工更新证件流程 ==

用户 -> "证件到期提醒页面": 点击【通知员工】按钮
activate "证件到期提醒页面"
"证件到期提醒页面" -> "后端服务": 提交通知请求\n(携带证件ID、通知方式)
activate "后端服务"
"后端服务" -> "数据库": 记录通知日志
activate "数据库"
"数据库" --> "后端服务": 返回记录结果
deactivate "数据库"
"后端服务" -> "后端服务": 发送通知\n(系统消息/邮件/企业微信)
"后端服务" --> "证件到期提醒页面": 返回成功响应
deactivate "后端服务"
"证件到期提醒页面" --> 用户: 显示"通知已发送"提示
deactivate "证件到期提醒页面"

== 确认证件更新流程 ==

用户 -> "证件到期提醒页面": 查看员工提交的更新申请
activate "证件到期提醒页面"
"证件到期提醒页面" -> "后端服务": 请求更新申请列表
activate "后端服务"
"后端服务" -> "数据库": 查询待确认的更新申请
activate "数据库"
"数据库" --> "后端服务": 返回申请列表
deactivate "数据库"
"后端服务" --> "证件到期提醒页面": 返回申请数据
deactivate "后端服务"
"证件到期提醒页面" --> 用户: 显示更新申请列表
deactivate "证件到期提醒页面"

用户 -> "证件到期提醒页面": 点击【确认更新】按钮
activate "证件到期提醒页面"
"证件到期提醒页面" -> "后端服务": 提交确认请求\n(携带新证件信息)
activate "后端服务"
"后端服务" -> "数据库": 更新证件信息
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 记录证件更新历史
activate "数据库"
"数据库" --> "后端服务": 返回记录结果
deactivate "数据库"
"后端服务" --> "证件到期提醒页面": 返回成功响应
deactivate "后端服务"
"证件到期提醒页面" --> 用户: 显示"证件已更新"提示\n刷新列表
deactivate "证件到期提醒页面"

== 查看更新历史流程 ==

用户 -> "证件到期提醒页面": 点击【查看历史】按钮
activate "证件到期提醒页面"
"证件到期提醒页面" -> "后端服务": 请求证件更新历史
activate "后端服务"
"后端服务" -> "数据库": 查询证件更新记录
activate "数据库"
"数据库" --> "后端服务": 返回历史记录
deactivate "数据库"
"后端服务" --> "证件到期提醒页面": 返回历史数据
deactivate "后端服务"
"证件到期提醒页面" --> 用户: 显示更新历史列表
deactivate "证件到期提醒页面"

@enduml
