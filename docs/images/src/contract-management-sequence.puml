@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "合同管理页面"
participant "后端服务"
database "数据库"

== 查看合同列表流程 ==

用户 -> "合同管理页面": 进入合同管理页面
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询合同数据
activate "数据库"
"数据库" --> "后端服务": 返回合同列表
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回列表数据
deactivate "后端服务"
"合同管理页面" --> 用户: 展示合同列表
deactivate "合同管理页面"

== 新增合同流程 ==

用户 -> "合同管理页面": 点击【新增合同】，填写表单
用户 -> "合同管理页面": 点击【保存】
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交新增请求\n(携带合同数据)
activate "后端服务"
"后端服务" -> "数据库": 插入合同记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回成功响应
deactivate "后端服务"
"合同管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同管理页面"

== 编辑合同流程 ==

用户 -> "合同管理页面": 点击【编辑】按钮
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询合同详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回详情数据
deactivate "后端服务"
"合同管理页面" --> 用户: 打开编辑弹窗\n回显数据
deactivate "合同管理页面"

用户 -> "合同管理页面": 修改数据，点击【保存】
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交更新请求
activate "后端服务"
"后端服务" -> "数据库": 更新合同记录
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回成功响应
deactivate "后端服务"
"合同管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同管理页面"

== 续签合同流程 ==

用户 -> "合同管理页面": 点击【续签】按钮
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求原合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询原合同数据
activate "数据库"
"数据库" --> "后端服务": 返回原合同数据
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回原合同数据
deactivate "后端服务"
"合同管理页面" --> 用户: 打开续签弹窗\n回显部分数据
deactivate "合同管理页面"

用户 -> "合同管理页面": 填写续签信息，点击【保存】
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交续签请求
activate "后端服务"
"后端服务" -> "数据库": 插入新合同记录\n更新原合同状态
activate "数据库"
"数据库" --> "后端服务": 返回操作结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回成功响应
deactivate "后端服务"
"合同管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同管理页面"

== 终止合同流程 ==

用户 -> "合同管理页面": 点击【终止】，填写终止原因
activate "合同管理页面"
"合同管理页面" -> "后端服务": 提交终止请求
activate "后端服务"
"后端服务" -> "数据库": 更新合同状态为已终止
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回成功响应
deactivate "后端服务"
"合同管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "合同管理页面"

== 查看详情流程 ==

用户 -> "合同管理页面": 点击【查看详情】按钮
activate "合同管理页面"
"合同管理页面" -> "后端服务": 请求合同详情
activate "后端服务"
"后端服务" -> "数据库": 查询合同详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "合同管理页面": 返回详情数据
deactivate "后端服务"
"合同管理页面" --> 用户: 显示合同详细信息\n提供下载功能
deactivate "合同管理页面"

@enduml
