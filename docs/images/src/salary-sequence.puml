@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "薪酬管理页面"
participant "后端服务"
database "数据库"

== 查看薪资结构列表流程 ==

用户 -> "薪酬管理页面": 进入薪资结构管理
activate "薪酬管理页面"
"薪酬管理页面" -> "后端服务": 请求薪资结构列表\n(携带查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询薪资结构数据
activate "数据库"
"数据库" --> "后端服务": 返回结构列表
deactivate "数据库"
"后端服务" --> "薪酬管理页面": 返回列表数据
deactivate "后端服务"
"薪酬管理页面" --> 用户: 展示薪资结构列表
deactivate "薪酬管理页面"

== 新增薪资结构流程 ==

用户 -> "薪酬管理页面": 点击【新增结构】，填写信息
用户 -> "薪酬管理页面": 点击【保存】
activate "薪酬管理页面"
"薪酬管理页面" -> "后端服务": 提交新增请求\n(携带结构数据)
activate "后端服务"
"后端服务" -> "数据库": 插入薪资结构记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "薪酬管理页面": 返回成功响应
deactivate "后端服务"
"薪酬管理页面" --> 用户: 显示成功提示\n刷新列表
deactivate "薪酬管理页面"

== 生成工资流程 ==

用户 -> "薪酬管理页面": 点击【生成工资】，选择月份和员工
用户 -> "薪酬管理页面": 点击【开始计算】
activate "薪酬管理页面"
"薪酬管理页面" -> "后端服务": 提交工资计算请求\n(携带月份和员工范围)
activate "后端服务"
"后端服务" -> "数据库": 查询员工基本信息
activate "数据库"
"数据库" --> "后端服务": 返回员工信息
deactivate "数据库"
"后端服务" -> "数据库": 查询薪资结构配置
activate "数据库"
"数据库" --> "后端服务": 返回薪资结构
deactivate "数据库"
"后端服务" -> "数据库": 查询考勤数据
activate "数据库"
"数据库" --> "后端服务": 返回考勤数据
deactivate "数据库"
"后端服务" -> "数据库": 查询社保数据
activate "数据库"
"数据库" --> "后端服务": 返回社保数据
deactivate "数据库"
"后端服务" -> "后端服务": 计算应发工资
"后端服务" -> "后端服务": 计算扣款项目
"后端服务" -> "后端服务": 计算实发工资
"后端服务" -> "数据库": 插入工资记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "薪酬管理页面": 返回计算结果
deactivate "后端服务"
"薪酬管理页面" --> 用户: 显示工资计算成功\n展示工资明细
deactivate "薪酬管理页面"

== 发放工资条流程 ==

用户 -> "薪酬管理页面": 点击【发放工资条】，选择月份和方式
用户 -> "薪酬管理页面": 点击【确认发放】
activate "薪酬管理页面"
"薪酬管理页面" -> "后端服务": 提交发放请求\n(携带月份和发放方式)
activate "后端服务"
"后端服务" -> "数据库": 查询工资记录
activate "数据库"
"数据库" --> "后端服务": 返回工资记录
deactivate "数据库"
"后端服务" -> "后端服务": 生成工资条
"后端服务" -> "后端服务": 发送工资条\n(邮件/短信/企业微信)
"后端服务" -> "数据库": 更新发放状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" --> "薪酬管理页面": 返回发放结果
deactivate "后端服务"
"薪酬管理页面" --> 用户: 显示发放成功\n刷新列表
deactivate "薪酬管理页面"

== 生成个税申报流程 ==

用户 -> "薪酬管理页面": 点击【生成申报】，选择月份
用户 -> "薪酬管理页面": 点击【确认】
activate "薪酬管理页面"
"薪酬管理页面" -> "后端服务": 提交生成申报请求\n(携带月份参数)
activate "后端服务"
"后端服务" -> "数据库": 查询工资记录
activate "数据库"
"数据库" --> "后端服务": 返回工资记录
deactivate "数据库"
"后端服务" -> "数据库": 查询专项附加扣除
activate "数据库"
"数据库" --> "后端服务": 返回扣除信息
deactivate "数据库"
"后端服务" -> "后端服务": 计算应纳税所得额
"后端服务" -> "后端服务": 计算累计预扣税额
"后端服务" -> "后端服务": 计算本期应缴税额
"后端服务" -> "数据库": 插入个税申报记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" --> "薪酬管理页面": 返回申报数据
deactivate "后端服务"
"薪酬管理页面" --> 用户: 显示申报表生成成功\n支持预览和导出
deactivate "薪酬管理页面"

== 提交调薪申请流程 ==

用户 -> "薪酬管理页面": 点击【调薪申请】，填写信息
用户 -> "薪酬管理页面": 点击【提交】
activate "薪酬管理页面"
"薪酬管理页面" -> "后端服务": 提交调薪申请\n(携带调薪数据)
activate "后端服务"
"后端服务" -> "数据库": 查询员工当前薪资
activate "数据库"
"数据库" --> "后端服务": 返回当前薪资
deactivate "数据库"
"后端服务" -> "数据库": 插入调薪申请记录
activate "数据库"
"数据库" --> "后端服务": 返回申请ID
deactivate "数据库"
"后端服务" -> "后端服务": 创建审批流程实例\n确定审批人
"后端服务" -> "后端服务": 发送审批通知
"后端服务" --> "薪酬管理页面": 返回成功响应
deactivate "后端服务"
"薪酬管理页面" --> 用户: 显示提交成功\n刷新列表
deactivate "薪酬管理页面"

== 审批通过后处理流程 ==

用户 -> "薪酬管理页面": 审批人审批通过调薪申请
activate "薪酬管理页面"
"薪酬管理页面" -> "后端服务": 提交审批结果
activate "后端服务"
"后端服务" -> "数据库": 更新申请状态为已通过
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 更新员工薪资信息
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 插入调薪历史记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "后端服务": 发送审批结果通知
"后端服务" --> "薪酬管理页面": 返回成功响应
deactivate "后端服务"
"薪酬管理页面" --> 用户: 显示审批成功\n刷新列表
deactivate "薪酬管理页面"

@enduml
