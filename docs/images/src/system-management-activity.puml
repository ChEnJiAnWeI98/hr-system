@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

start
:进入系统管理页面;
:查看管理功能列表;

:选择操作;

if (操作类型?) then (用户账号管理)
  :点击【用户账号管理】;
  :查看用户列表;
  if (子操作?) then (新增用户)
    :点击【新增用户】按钮;
    :填写用户信息;
    :分配角色;
    if (数据验证?) then (验证通过)
      :保存成功
      刷新列表;
    else (验证失败)
      :显示错误提示
      停留在表单;
      :重新填写;
      detach
    endif
  elseif (子操作?) then (编辑用户)
    :点击【编辑】按钮;
    :修改用户信息;
    :调整角色;
    :保存成功
    刷新列表;
  else (禁用/启用)
    :点击【禁用/启用】按钮;
    :确认操作;
    :状态变更成功
    刷新列表;
  endif
elseif (操作类型?) then (角色权限管理)
  :点击【角色权限管理】;
  :查看角色列表;
  if (子操作?) then (新增角色)
    :点击【新增角色】按钮;
    :填写角色信息;
    :配置菜单权限;
    :配置按钮权限;
    :配置数据权限;
    if (数据验证?) then (验证通过)
      :保存成功
      刷新列表;
    else (验证失败)
      :显示错误提示
      停留在表单;
      :重新填写;
      detach
    endif
  else (编辑权限)
    :点击【编辑权限】按钮;
    :调整权限配置;
    :保存成功
    刷新列表;
  endif
elseif (操作类型?) then (数据字典管理)
  :点击【数据字典管理】;
  :查看字典分类;
  if (子操作?) then (新增字典项)
    :点击【新增字典项】按钮;
    :填写字典信息;
    :设置排序;
    if (数据验证?) then (验证通过)
      :保存成功
      刷新列表;
    else (验证失败)
      :显示错误提示
      停留在表单;
      :重新填写;
      detach
    endif
  else (编辑字典)
    :点击【编辑】按钮;
    :修改字典信息;
    :保存成功
    刷新列表;
  endif
elseif (操作类型?) then (操作日志查询)
  :点击【操作日志】;
  :设置查询条件;
  :查看日志列表;
  :可导出日志;
elseif (操作类型?) then (消息通知配置)
  :点击【消息通知配置】;
  :选择通知场景;
  :配置通知渠道;
  :编辑通知模板;
  if (确认保存?) then (确认)
    :保存配置
    刷新列表;
  else (取消)
    stop
  endif
else (系统参数设置)
  :点击【系统参数设置】;
  :修改系统参数;
  :上传Logo;
  :配置集成参数;
  if (确认保存?) then (确认)
    :保存参数
    系统重新加载配置;
  else (取消)
    stop
  endif
endif

stop

@enduml
