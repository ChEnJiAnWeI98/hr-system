@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "离职管理页面"
participant "后端服务"
database "数据库"

== 查看离职列表流程 ==

用户 -> "离职管理页面": 进入离职管理页面
activate "离职管理页面"
"离职管理页面" -> "后端服务": 请求离职申请列表\n(携带默认查询参数)
activate "后端服务"
"后端服务" -> "数据库": 查询离职申请记录
activate "数据库"
"数据库" --> "后端服务": 返回离职申请列表
deactivate "数据库"
"后端服务" --> "离职管理页面": 返回列表数据
deactivate "后端服务"
"离职管理页面" --> 用户: 展示离职申请列表
deactivate "离职管理页面"

== 发起离职申请流程 ==

用户 -> "离职管理页面": 点击【发起离职】按钮
activate "离职管理页面"
"离职管理页面" --> 用户: 打开离职申请表单
deactivate "离职管理页面"

用户 -> "离职管理页面": 填写离职信息，点击【提交】
activate "离职管理页面"
"离职管理页面" -> "后端服务": 提交离职申请\n(携带表单数据)
activate "后端服务"
"后端服务" -> "数据库": 插入离职申请记录
activate "数据库"
"数据库" --> "后端服务": 返回插入结果
deactivate "数据库"
"后端服务" -> "数据库": 发送审批通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "离职管理页面": 返回成功响应
deactivate "后端服务"
"离职管理页面" --> 用户: 显示"提交成功"\n刷新列表
deactivate "离职管理页面"

== 审批离职申请流程 ==

用户 -> "离职管理页面": 点击【审批】按钮
activate "离职管理页面"
"离职管理页面" -> "后端服务": 请求离职申请详情
activate "后端服务"
"后端服务" -> "数据库": 查询离职申请详情
activate "数据库"
"数据库" --> "后端服务": 返回详情数据
deactivate "数据库"
"后端服务" --> "离职管理页面": 返回详情数据
deactivate "后端服务"
"离职管理页面" --> 用户: 打开审批弹窗\n回显申请信息
deactivate "离职管理页面"

用户 -> "离职管理页面": 填写审批意见，点击【通过】或【拒绝】
activate "离职管理页面"
"离职管理页面" -> "后端服务": 提交审批结果
activate "后端服务"
"后端服务" -> "数据库": 更新审批状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 发送审批结果通知
activate "数据库"
"数据库" --> "后端服务": 通知发送成功
deactivate "数据库"
"后端服务" --> "离职管理页面": 返回成功响应
deactivate "后端服务"
"离职管理页面" --> 用户: 显示"审批成功"\n刷新列表
deactivate "离职管理页面"

== 办理离职手续流程 ==

用户 -> "离职管理页面": 点击【办理手续】按钮
activate "离职管理页面"
"离职管理页面" -> "后端服务": 请求离职手续清单
activate "后端服务"
"后端服务" -> "数据库": 查询手续清单模板
activate "数据库"
"数据库" --> "后端服务": 返回清单数据
deactivate "数据库"
"后端服务" --> "离职管理页面": 返回清单数据
deactivate "后端服务"
"离职管理页面" --> 用户: 展示手续清单
deactivate "离职管理页面"

用户 -> "离职管理页面": 逐项确认手续，点击【完成办理】
activate "离职管理页面"
"离职管理页面" -> "后端服务": 提交手续办理结果
activate "后端服务"
"后端服务" -> "数据库": 更新手续办理状态
activate "数据库"
"数据库" --> "后端服务": 返回更新结果
deactivate "数据库"
"后端服务" -> "数据库": 更新员工状态为"已离职"
activate "数据库"
"数据库" --> "后端服务": 状态更新成功
deactivate "数据库"
"后端服务" -> "数据库": 停用系统账号
activate "数据库"
"数据库" --> "后端服务": 账号停用成功
deactivate "数据库"
"后端服务" --> "离职管理页面": 返回成功响应
deactivate "后端服务"
"离职管理页面" --> 用户: 显示"离职办理完成"\n刷新列表
deactivate "离职管理页面"

@enduml
