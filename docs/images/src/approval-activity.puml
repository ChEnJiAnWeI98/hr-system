@startuml
skinparam backgroundColor #FFFFFF
skinparam activityBackgroundColor #e3f2fd
skinparam activityBorderColor #90caf9
skinparam activityStartColor #e8f5e9
skinparam activityEndColor #e8f5e9
skinparam activityDiamondBackgroundColor #fff3e0
skinparam activityDiamondBorderColor #ffb74d

title 审批流引擎用户操作流程

|管理员|
start
:进入审批流引擎管理页面;
:选择"流程模板管理";
:查看流程模板列表;

:点击【新增模板】按钮;
:填写模板基本信息
（模板名称、适用范围、说明）;
:在流程设计器中拖拽配置审批节点;
:设置每个节点的审批人
（指定人员、指定角色、部门负责人等）;
:设置条件分支规则
（根据金额、部门、职级自动路由）;
:点击【保存】按钮;

if (流程配置验证) then (通过)
  #d5e8d4:保存模板成功
  刷新列表;
else (失败)
  #fce4ec:显示错误提示
  停留在设计器页面;
  stop
endif

|用户|
:进入审批实例管理页面;
:查看所有审批实例列表;
:点击【发起审批】按钮;
:选择审批类型
（请假审批、报销审批、采购审批等）;
:填写审批表单;
:上传附件
（请假条、发票、合同等）;
:点击【提交】按钮;

if (表单数据验证) then (通过)
  #d5e8d4:创建审批实例成功
  确定审批节点和审批人
  发送审批通知
  显示提交成功提示
  刷新列表;
else (失败)
  #fce4ec:显示错误提示
  停留在表单页面;
  stop
endif

:查看审批详情、审批进度、审批历史;

if (是否需要撤回?) then (是)
  if (审批是否已开始处理?) then (否)
    :点击【撤回】按钮;
    #d5e8d4:撤回成功
    刷新列表;
  else (是)
    #fce4ec:无法撤回
    审批已开始处理;
    stop
  endif
else (否)
endif

|审批人|
:进入待办审批页面;
:查看待处理的审批列表;
:点击【审批】按钮;
:查看审批详情
（审批表单、附件、审批历史）;
:填写审批意见;

if (选择审批操作) then (通过)
  :点击【通过】按钮;
  if (是否为最后节点?) then (是)
    #d5e8d4:更新审批实例状态为"已完成"
    更新业务状态
    发送完成通知;
  else (否)
    #d5e8d4:流转到下一节点
    发送下一节点审批通知;
  endif
elseif (驳回) then
  :点击【驳回】按钮;
  :填写驳回原因;
  #fce4ec:更新审批节点状态为"驳回"
  流转到发起人
  发送驳回通知;
elseif (转签) then
  :点击【转签】按钮;
  :选择转签人;
  :填写转签原因;
  #d5e8d4:更新审批节点审批人为转签人
  发送转签通知;
elseif (加签) then
  :点击【加签】按钮;
  :选择加签人和加签位置
  （前加签/后加签）;
  :填写加签原因;
  #d5e8d4:插入新的审批节点
  发送加签通知;
endif

|用户|
:进入代理设置页面;
:查看当前代理设置列表;
:点击【新增代理】按钮;
:选择代理人;
:设置代理时间范围
（开始时间、结束时间）;
:选择代理范围
（全部审批/指定审批类型）;
:点击【保存】按钮;

#d5e8d4:保存代理设置成功
显示成功提示
刷新列表;

note right
  代理期间，符合代理范围的
  审批任务自动转给代理人处理

  代理期结束后，系统自动
  停用代理设置
end note

stop

@enduml
