# 【环境变量模板】
# 用法：复制本文件为 .env，并填入你本地的真实值
# 注意：.env 已在 .gitignore 中，不会提交到 git；本模板只列字段名 + 占位值

# 版本号
VITE_VERSION = 1.0.0

# 端口号
VITE_PORT = 3006

# 应用部署基础路径（部署到子目录如 /admin 时设为 /admin/）
VITE_BASE_URL = /

# 权限模式 [ frontend 前端模式 / backend 后端模式 ]
VITE_ACCESS_MODE = backend

# Mock 模式（无需后端 API，使用本地预置数据） [ true / false ]
VITE_USE_MOCK = true

# 跨域请求时是否携带 Cookie（开启前需确保后端支持）
VITE_WITH_CREDENTIALS = false

# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false

# 锁屏加密密钥（请用本地随机字符串，建议 12+ 位字母数字）
VITE_LOCK_ENCRYPT_KEY = your_random_encryption_key_here
